---
interface Props {
  title:       string;
  slug:        string;
  description: string;
  publishedAt: Date;
  tags:        string[];
}

const { title, slug, description, publishedAt, tags } = Astro.props;

const dateStr = publishedAt.toLocaleDateString('en-US', {
  year:  'numeric',
  month: 'short',
  day:   'numeric',
});
---

<article class="blog-card" data-spotlight data-slug={slug} data-title={title.toLowerCase()} data-tags={tags.join(',').toLowerCase()} data-desc={description.toLowerCase()}>
  <a href={`/writing/${slug}`} class="blog-card-link" aria-label={title}>
    <time class="blog-card-date label" datetime={publishedAt.toISOString()}>
      {dateStr}
    </time>

    <h2 class="blog-card-title">{title}</h2>

    <p class="blog-card-desc">{description}</p>

    <div class="blog-card-footer">
      <div class="blog-card-tags">
        {tags.slice(0, 2).map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
      <span class="blog-card-read label">Read →</span>
    </div>
  </a>
</article>

<style>
  .blog-card {
    border: 1px solid var(--ink-4);
    border-radius: 6px;
    background-color: var(--ink-2);
    box-shadow: var(--shadow-sm);
    transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }
  .blog-card:hover {
    border-color: var(--copper);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .blog-card-link {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 22px;
    height: 100%;
    color: inherit;
  }
  .blog-card-link:hover { color: inherit; }

  .blog-card-date {
    display: block;
  }

  .blog-card-title {
    font-size: 18px;
    font-weight: 500;
    line-height: 1.25;
    color: var(--parchment);
    transition: color 180ms ease;
  }
  .blog-card:hover .blog-card-title { color: var(--parchment); }

  .blog-card-desc {
    font-size: 13px;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex-grow: 1;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4px;
  }

  .blog-card-tags {
    display: flex;
    gap: 10px;
  }

  .blog-card-read {
    color: var(--parchment-4);
    transition: color 150ms ease;
  }
  .blog-card:hover .blog-card-read { color: var(--copper); }
</style>
