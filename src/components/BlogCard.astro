---
interface Props {
  title:       string;
  description: string;
  publishedAt: Date;
  tags:        string[];
  slug:        string;
}

const { title, description, publishedAt, tags, slug } = Astro.props;

const dateStr = publishedAt.toLocaleDateString('en-US', {
  month: 'short',
  year:  'numeric',
});
---

<article class="blog-card">
  <div class="blog-card-meta">
    <time datetime={publishedAt.toISOString()} class="blog-card-date">{dateStr}</time>
    <div class="blog-card-tags">
      {tags.slice(0, 3).map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  </div>

  <h3 class="blog-card-title">
    <a href={`/writing/${slug}`} class="blog-card-link">{title}</a>
  </h3>

  <p class="blog-card-desc">{description}</p>

  <a href={`/writing/${slug}`} class="blog-card-read" aria-hidden="true">
    Read →
  </a>
</article>

<style>
  .blog-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform var(--t), box-shadow var(--t), border-color var(--t);
  }

  .blog-card:hover {
    transform: translate3d(0, -4px, 0);
    box-shadow: var(--shadow-lift);
    border-color: var(--accent);
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .blog-card-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    flex-shrink: 0;
  }

  .blog-card-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .blog-card-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.3;
  }

  .blog-card-link {
    color: var(--text);
    transition: color var(--t);
  }

  .blog-card:hover .blog-card-link {
    color: var(--secondary);
  }

  .blog-card-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .blog-card-read {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    align-self: flex-start;
    transition: color var(--t);
  }

  .blog-card:hover .blog-card-read {
    color: var(--secondary);
  }
</style>
