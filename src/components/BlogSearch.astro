---
import type { CollectionEntry } from 'astro:content';
import BlogCard from './BlogCard.astro';

interface Props {
  posts: CollectionEntry<'writing'>[];
  postsPerPage?: number;
}

const { posts, postsPerPage = 6 } = Astro.props;

// Collect all unique tags
const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();

// Serialize posts for client-side JS
const postsData = posts.map(p => ({
  slug:        p.id.replace(/\.md$/, ''),
  title:       p.data.title,
  description: p.data.description,
  tags:        p.data.tags,
  publishedAt: p.data.publishedAt.toISOString(),
}));
---

<div class="search-wrap">
  <!-- Search input -->
  <div class="search-bar-wrap">
    <label for="blog-search" class="sr-only">Search posts</label>
    <img
      src="https://img.icons8.com/ios-filled/40/6c735f/search.png"
      alt=""
      width="14"
      height="14"
      class="search-icon"
    />
    <input
      id="blog-search"
      type="search"
      placeholder="Search posts…"
      class="search-input"
      autocomplete="off"
      spellcheck="false"
    />
  </div>

  <!-- Tag filter pills -->
  {allTags.length > 0 && (
    <div class="tag-filters" role="group" aria-label="Filter by tag">
      {allTags.map(tag => (
        <button
          class="tag-pill"
          data-tag={tag.toLowerCase()}
          type="button"
          aria-pressed="false"
        >
          {tag}
        </button>
      ))}
    </div>
  )}

  <!-- Results count -->
  <p class="search-meta label" id="search-meta" aria-live="polite" aria-atomic="true"></p>
</div>

<!-- Post grid — all cards rendered server-side, JS controls visibility -->
<div class="post-grid" id="post-grid">
  {posts.map(post => (
    <BlogCard
      title={post.data.title}
      slug={post.id.replace(/\.md$/, '')}
      description={post.data.description}
      publishedAt={post.data.publishedAt}
      tags={post.data.tags}
    />
  ))}
</div>

<!-- Client-side pagination -->
<nav class="pagination" id="pagination" aria-label="Posts pagination"></nav>

<p class="no-results label" id="no-results" hidden>No posts match your search.</p>

<script define:vars={{ postsData, postsPerPage }}>
  const grid      = document.getElementById('post-grid');
  const paginNav  = document.getElementById('pagination');
  const noResults = document.getElementById('no-results');
  const metaEl    = document.getElementById('search-meta');
  const searchEl  = document.getElementById('blog-search');
  const tagBtns   = document.querySelectorAll('.tag-pill');
  const cards     = Array.from(grid.querySelectorAll('.blog-card'));

  let query      = '';
  let activeTag  = '';
  let currentPage = 1;

  // ── Filter logic ─────────────────────────────────────
  function getMatches() {
    return postsData.filter(p => {
      const haystack = `${p.title} ${p.description} ${p.tags.join(' ')}`.toLowerCase();
      const matchQ   = !query    || haystack.includes(query);
      const matchT   = !activeTag || p.tags.map(t => t.toLowerCase()).includes(activeTag);
      return matchQ && matchT;
    });
  }

  // ── Render ────────────────────────────────────────────
  function render() {
    const matches    = getMatches();
    const isFiltered = query || activeTag;
    const total      = matches.length;

    // Show/hide cards
    const pageMatches = isFiltered
      ? matches
      : matches.slice((currentPage - 1) * postsPerPage, currentPage * postsPerPage);

    const visibleSlugs = new Set(pageMatches.map(p => p.slug));

    cards.forEach(card => {
      const slug = card.dataset.slug;
      if (visibleSlugs.has(slug)) {
        card.removeAttribute('hidden');
        card.style.opacity = '1';
      } else {
        card.setAttribute('hidden', '');
      }
    });

    // No results
    noResults.hidden = total > 0;
    grid.hidden = total === 0;

    // Meta
    if (isFiltered) {
      metaEl.textContent = `${total} post${total !== 1 ? 's' : ''} found`;
    } else {
      metaEl.textContent = '';
    }

    // Pagination — only when not searching/filtering
    if (isFiltered) {
      paginNav.hidden = true;
    } else {
      const totalPages = Math.ceil(total / postsPerPage);
      renderPagination(currentPage, totalPages);
      paginNav.hidden = totalPages <= 1;
    }
  }

  // ── Pagination controls ───────────────────────────────
  function renderPagination(page, total) {
    if (total <= 1) { paginNav.innerHTML = ''; return; }

    let html = '';

    // Prev
    if (page > 1) {
      html += `<button class="page-btn" data-page="${page - 1}">← Prev</button>`;
    } else {
      html += `<span class="page-btn page-btn--disabled">← Prev</span>`;
    }

    // Page numbers
    for (let i = 1; i <= total; i++) {
      html += `<button class="page-btn ${i === page ? 'page-btn--active' : ''}" data-page="${i}">${i}</button>`;
    }

    // Next
    if (page < total) {
      html += `<button class="page-btn" data-page="${page + 1}">Next →</button>`;
    } else {
      html += `<span class="page-btn page-btn--disabled">Next →</span>`;
    }

    paginNav.innerHTML = html;

    // Bind pagination clicks
    paginNav.querySelectorAll('[data-page]').forEach(btn => {
      btn.addEventListener('click', () => {
        currentPage = Number(btn.dataset.page);
        render();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });
  }

  // ── Search debounce ────────────────────────────────────
  let debounceTimer;
  searchEl?.addEventListener('input', e => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      query = e.target.value.trim().toLowerCase();
      currentPage = 1;
      render();
    }, 200);
  });

  // ── Tag filter ─────────────────────────────────────────
  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag;
      if (activeTag === tag) {
        activeTag = '';
        btn.setAttribute('aria-pressed', 'false');
        btn.classList.remove('tag-pill--active');
      } else {
        activeTag = tag;
        tagBtns.forEach(b => {
          b.setAttribute('aria-pressed', 'false');
          b.classList.remove('tag-pill--active');
        });
        btn.setAttribute('aria-pressed', 'true');
        btn.classList.add('tag-pill--active');
      }
      currentPage = 1;
      render();
    });
  });

  // Initial render
  render();
</script>

<style>
  .search-wrap {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 40px;
  }

  .search-bar-wrap {
    position: relative;
  }

  .search-icon {
    position: absolute;
    top: 50%;
    left: 14px;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    background: var(--ink-2);
    border: 1px solid var(--ink-4);
    border-radius: 3px;
    color: var(--parchment);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 300;
    padding: 10px 14px 10px 36px;
    transition: border-color 150ms ease;
  }
  .search-input::placeholder { color: var(--parchment-4); }
  .search-input:focus {
    outline: none;
    border-color: var(--parchment-4);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--copper) 25%, transparent);
  }

  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--parchment-4);
    background: none;
    border: 1px solid var(--ink-4);
    border-radius: 2px;
    padding: 4px 10px;
    cursor: pointer;
    transition: border-color 150ms ease, color 150ms ease;
  }
  .tag-pill:hover {
    border-color: var(--parchment-4);
    color: var(--parchment-3);
  }
  .tag-pill--active {
    border-color: var(--copper);
    color: var(--parchment-2);
  }

  .search-meta {
    color: var(--parchment-4);
    min-height: 1em;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }

  .no-results {
    text-align: center;
    padding: 40px 0;
    color: var(--parchment-4);
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .page-btn {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--parchment-4);
    background: none;
    border: none;
    padding: 6px 10px;
    cursor: pointer;
    transition: color 150ms ease;
    border-radius: 2px;
  }
  .page-btn:hover { color: var(--parchment-2); }
  .page-btn--active { color: var(--parchment); }
  .page-btn--disabled {
    opacity: 0.35;
    cursor: default;
    pointer-events: none;
  }

  @media (max-width: 600px) {
    .post-grid { grid-template-columns: 1fr; }
  }
</style>
