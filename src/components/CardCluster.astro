---
// 3D card cluster — CSS perspective + rotateX/Y. Parallax via vanilla JS.
// Desktop only; hidden on mobile via parent Hero styles.
---

<div class="cluster-wrap" id="card-cluster" aria-hidden="true">
  <!-- Back card -->
  <div class="card card--back">
    <span class="card-label">pm roadmap</span>
    <p class="card-text">6-month transition plan</p>
    <div class="card-bar">
      <div class="card-bar-fill" style="width: 62%"></div>
    </div>
    <span class="card-pct">62%</span>
  </div>

  <!-- Middle card -->
  <div class="card card--mid">
    <span class="card-label">data analysis</span>
    <p class="card-text">SQL · Python · Sheets</p>
    <div class="card-bar">
      <div class="card-bar-fill" style="width: 80%"></div>
    </div>
    <span class="card-pct">80%</span>
  </div>

  <!-- Front card -->
  <div class="card card--front">
    <span class="card-label">industrial eng.</span>
    <p class="card-text">Systems thinking</p>
    <div class="card-bar">
      <div class="card-bar-fill" style="width: 90%"></div>
    </div>
    <span class="card-pct">90%</span>
  </div>
</div>

<script>
  const cluster = document.getElementById('card-cluster');
  if (cluster) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const y = window.scrollY * 0.07;
          cluster.style.transform = `translateY(${y}px)`;
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
</script>

<style>
  .cluster-wrap {
    position: relative;
    width: 220px;
    height: 200px;
    flex-shrink: 0;
    will-change: transform;
  }

  .card {
    position: absolute;
    inset: 0;
    width: 200px;
    height: 160px;
    background: var(--ink-2);
    border: 1px solid var(--ink-4);
    border-radius: 4px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Stacked depth: each behind card offset + lower z-index */
  .card--back {
    transform: perspective(500px) rotateX(4deg) rotateY(-8deg)
               translate3d(-6px, -6px, -50px);
    z-index: 1;
    box-shadow: -3px 3px 0 #0a0908;
  }

  .card--mid {
    transform: perspective(500px) rotateX(4deg) rotateY(-8deg)
               translate3d(-3px, -3px, -25px);
    z-index: 2;
    box-shadow: -3px 3px 0 #0a0908;
  }

  .card--front {
    transform: perspective(500px) rotateX(4deg) rotateY(-8deg)
               translate3d(0, 0, 0);
    z-index: 3;
  }

  /* Card content */
  .card-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-4);
  }

  .card-text {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 400;
    color: var(--parchment);
    line-height: 1.2;
    margin: 0;
  }

  .card-bar {
    height: 2px;
    background: var(--ink-4);
    border-radius: 1px;
    margin-top: auto;
    overflow: hidden;
  }

  .card-bar-fill {
    height: 100%;
    background: var(--parchment-4);
    border-radius: 1px;
  }

  .card-pct {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--parchment-4);
    letter-spacing: 0.5px;
    align-self: flex-end;
    margin-top: -4px;
  }
</style>
