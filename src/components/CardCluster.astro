---
// 3D card cluster — CSS perspective + rotateX/Y. Parallax via vanilla JS.
// Desktop only; hidden on mobile via parent Hero styles.
---

<div class="cluster-wrap" id="card-cluster" aria-hidden="true">
  <!-- Back card -->
  <div class="card card--back">
    <span class="card-label">supply chain</span>
    <p class="card-text">Route optimization</p>
    <div class="card-bar">
      <div class="card-bar-fill" style="width: 62%"></div>
    </div>
    <span class="card-pct">-31% miles</span>
  </div>

  <!-- Middle card -->
  <div class="card card--mid">
    <span class="card-label">revops</span>
    <p class="card-text">n8n · Python · Docker</p>
    <div class="card-bar">
      <div class="card-bar-fill" style="width: 80%"></div>
    </div>
    <span class="card-pct">24/7 uptime</span>
  </div>

  <!-- Front card -->
  <div class="card card--front">
    <span class="card-label">gtm</span>
    <p class="card-text">Lead follow-up automation</p>
    <div class="card-bar">
      <div class="card-bar-fill" style="width: 90%"></div>
    </div>
    <span class="card-pct">&lt;2min response</span>
  </div>

  <!-- Pipeline diagram — echoes the card stack with connected, "live" nodes -->
  <svg class="cluster-diagram" viewBox="0 0 250 210" aria-hidden="true">
    <path id="diagram-path" d="M170 140 L196 162 L218 184" class="diagram-line" />
    <circle cx="170" cy="140" r="3" class="diagram-node" />
    <circle cx="196" cy="162" r="3" class="diagram-node" />
    <circle cx="218" cy="184" r="3" class="diagram-node" />
    <circle id="diagram-pulse" cx="170" cy="140" r="3.5" class="diagram-pulse" />
  </svg>
</div>

<script>
  import { gsap } from 'gsap';

  const cluster = document.getElementById('card-cluster');
  const cards = cluster ? Array.from(cluster.querySelectorAll<HTMLElement>('.card')) : [];
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const diagramPath = document.getElementById('diagram-path') as SVGPathElement | null;
  const diagramNodes = cluster ? Array.from(cluster.querySelectorAll('.diagram-node')) : [];
  const pulse = document.getElementById('diagram-pulse');
  const nodePoints = [
    { x: 170, y: 140 },
    { x: 196, y: 162 },
    { x: 218, y: 184 },
  ];

  if (cluster) {
    if (prefersReducedMotion) {
      gsap.set(cards, { opacity: 1 });
      gsap.set([diagramPath, ...diagramNodes], { opacity: 1 });
      if (pulse) gsap.set(pulse, { opacity: 0 });
    } else {
      // Entrance: cluster scales/fades in, cards stagger in back-to-front.
      gsap.fromTo(
        cluster,
        { opacity: 0, scale: 0.92 },
        { opacity: 1, scale: 1, duration: 0.7, ease: 'power3.out', delay: 0.35 },
      );
      gsap.fromTo(
        cards,
        { opacity: 0 },
        { opacity: 1, duration: 0.5, ease: 'power2.out', stagger: 0.12, delay: 0.45 },
      );

      // Diagram: draw the connector path, pop the nodes, then start the
      // pulse traveling along it — a small "automation is live" motif.
      if (diagramPath) {
        const length = diagramPath.getTotalLength();
        gsap.set(diagramPath, { opacity: 1, strokeDasharray: length, strokeDashoffset: length });
        gsap.to(diagramPath, {
          strokeDashoffset: 0,
          duration: 0.6,
          ease: 'power2.inOut',
          delay: 0.9,
        });
      }
      gsap.fromTo(
        diagramNodes,
        { opacity: 0, scale: 0, transformOrigin: 'center' },
        { opacity: 1, scale: 1, duration: 0.3, ease: 'back.out(3)', stagger: 0.15, delay: 1.0 },
      );

      if (pulse) {
        const tl = gsap.timeline({ delay: 1.6, repeat: -1, repeatDelay: 0.6 });
        nodePoints.forEach((point, i) => {
          if (i === 0) {
            tl.set(pulse, { attr: { cx: point.x, cy: point.y }, opacity: 1 });
          } else {
            tl.to(pulse, {
              attr: { cx: point.x, cy: point.y },
              duration: 0.5,
              ease: 'power1.inOut',
            });
          }
        });
        tl.to(pulse, { opacity: 0, duration: 0.2 });
      }

      // Smooth scroll parallax via GSAP's interpolated quickTo.
      const yTo = gsap.quickTo(cluster, 'y', { duration: 0.5, ease: 'power2.out' });
      window.addEventListener(
        'scroll',
        () => yTo(window.scrollY * 0.07),
        { passive: true },
      );
    }
  }
</script>

<style>
  /* Pre-hide for JS-driven entrance — avoided when motion is reduced or
     JS never runs, so the cluster is never permanently invisible. */
  :global(.js) .cluster-wrap,
  :global(.js) .card,
  :global(.js) .diagram-line,
  :global(.js) .diagram-node {
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.js) .cluster-wrap,
    :global(.js) .card,
    :global(.js) .diagram-line,
    :global(.js) .diagram-node {
      opacity: 1;
    }
  }

  .cluster-wrap {
    position: relative;
    width: 250px;
    height: 210px;
    flex-shrink: 0;
    will-change: transform;
  }

  /* Pipeline diagram overlay — small "automation is live" graphic that
     echoes the cards' staircase offset in the cluster's open corner. */
  .cluster-diagram {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 4;
    overflow: visible;
  }

  .diagram-line {
    fill: none;
    stroke: var(--ink-4);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .diagram-node {
    fill: var(--ink);
    stroke: var(--copper);
    stroke-width: 1.5;
  }

  .diagram-pulse {
    fill: var(--copper);
    opacity: 0;
  }

  .card {
    position: absolute;
    inset: 0;
    width: 200px;
    height: 160px;
    background: var(--ink-2);
    border: 1px solid var(--ink-4);
    border-radius: 4px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Stacked depth: each behind card offset + lower z-index */
  .card--back {
    transform: perspective(500px) rotateX(4deg) rotateY(-8deg)
               translate3d(-6px, -6px, -50px);
    z-index: 1;
    box-shadow: -3px 3px 0 var(--ink);
  }

  .card--mid {
    transform: perspective(500px) rotateX(4deg) rotateY(-8deg)
               translate3d(-3px, -3px, -25px);
    z-index: 2;
    box-shadow: -3px 3px 0 var(--ink);
  }

  .card--front {
    transform: perspective(500px) rotateX(4deg) rotateY(-8deg)
               translate3d(0, 0, 0);
    z-index: 3;
  }

  /* Card content */
  .card-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-4);
  }

  .card-text {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 400;
    color: var(--parchment);
    line-height: 1.2;
    margin: 0;
  }

  .card-bar {
    height: 2px;
    background: var(--ink-4);
    border-radius: 1px;
    margin-top: auto;
    overflow: hidden;
  }

  .card-bar-fill {
    height: 100%;
    background: var(--copper);
    border-radius: 1px;
  }

  .card-pct {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--parchment-4);
    letter-spacing: 0.5px;
    align-self: flex-end;
    margin-top: -4px;
  }
</style>
