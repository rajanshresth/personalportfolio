---
// 3D card cluster — CSS perspective + rotateX/Y. Parallax via vanilla JS.
// Desktop only; hidden on mobile via parent Hero styles.
---

<div class="cluster-wrap" id="card-cluster" aria-hidden="true">
  <!-- Back card -->
  <div class="card card--back">
    <span class="card-label">supply chain</span>
    <p class="card-text">Route optimization</p>
    <div class="card-bar">
      <div class="card-bar-fill" style="width: 62%"></div>
    </div>
    <span class="card-pct">-31% miles</span>
  </div>

  <!-- Middle card -->
  <div class="card card--mid">
    <span class="card-label">revops</span>
    <p class="card-text">n8n · Python · Docker</p>
    <div class="card-bar">
      <div class="card-bar-fill" style="width: 80%"></div>
    </div>
    <span class="card-pct">24/7 uptime</span>
  </div>

  <!-- Front card -->
  <div class="card card--front">
    <span class="card-label">gtm</span>
    <p class="card-text">Lead follow-up automation</p>
    <div class="card-bar">
      <div class="card-bar-fill" style="width: 90%"></div>
    </div>
    <span class="card-pct">&lt;2min response</span>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  const cluster = document.getElementById('card-cluster');
  const cards = cluster ? Array.from(cluster.querySelectorAll<HTMLElement>('.card')) : [];
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (cluster) {
    if (prefersReducedMotion) {
      gsap.set(cards, { opacity: 1 });
    } else {
      // Entrance: cluster scales/fades in, cards stagger in back-to-front.
      gsap.fromTo(
        cluster,
        { opacity: 0, scale: 0.92 },
        { opacity: 1, scale: 1, duration: 0.7, ease: 'power3.out', delay: 0.35 },
      );
      gsap.fromTo(
        cards,
        { opacity: 0 },
        { opacity: 1, duration: 0.5, ease: 'power2.out', stagger: 0.12, delay: 0.45 },
      );

      // Smooth scroll parallax via GSAP's interpolated quickTo.
      const yTo = gsap.quickTo(cluster, 'y', { duration: 0.5, ease: 'power2.out' });
      window.addEventListener(
        'scroll',
        () => yTo(window.scrollY * 0.07),
        { passive: true },
      );
    }
  }
</script>

<style>
  /* Pre-hide for JS-driven entrance — avoided when motion is reduced or
     JS never runs, so the cluster is never permanently invisible. */
  :global(.js) .cluster-wrap,
  :global(.js) .card {
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.js) .cluster-wrap,
    :global(.js) .card {
      opacity: 1;
    }
  }

  .cluster-wrap {
    position: relative;
    width: 220px;
    height: 200px;
    flex-shrink: 0;
    will-change: transform;
  }

  .card {
    position: absolute;
    inset: 0;
    width: 200px;
    height: 160px;
    background: var(--ink-2);
    border: 1px solid var(--ink-4);
    border-radius: 4px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Stacked depth: each behind card offset + lower z-index */
  .card--back {
    transform: perspective(500px) rotateX(4deg) rotateY(-8deg)
               translate3d(-6px, -6px, -50px);
    z-index: 1;
    box-shadow: -3px 3px 0 var(--ink);
  }

  .card--mid {
    transform: perspective(500px) rotateX(4deg) rotateY(-8deg)
               translate3d(-3px, -3px, -25px);
    z-index: 2;
    box-shadow: -3px 3px 0 var(--ink);
  }

  .card--front {
    transform: perspective(500px) rotateX(4deg) rotateY(-8deg)
               translate3d(0, 0, 0);
    z-index: 3;
  }

  /* Card content */
  .card-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-4);
  }

  .card-text {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 400;
    color: var(--parchment);
    line-height: 1.2;
    margin: 0;
  }

  .card-bar {
    height: 2px;
    background: var(--ink-4);
    border-radius: 1px;
    margin-top: auto;
    overflow: hidden;
  }

  .card-bar-fill {
    height: 100%;
    background: var(--parchment-4);
    border-radius: 1px;
  }

  .card-pct {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--parchment-4);
    letter-spacing: 0.5px;
    align-self: flex-end;
    margin-top: -4px;
  }
</style>
