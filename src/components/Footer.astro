---
const year = 2024;
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-logo">Rajan</div>

    <p class="footer-copy">
      &copy; {year} Rajan Shrestha. All rights reserved.
    </p>

    <div class="footer-links">
      <a href="mailto:shrestharajan726@gmail.com" class="footer-link label">
        Email: shrestharajan726@gmail.com
      </a>
      <a
        href="https://www.linkedin.com/in/rajan10x/"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-link label"
        aria-label="LinkedIn profile"
      >
        LinkedIn
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--ink-4);
    background: var(--ink-2);
    padding: 24px 0;
    margin-top: auto;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--copper);
  }

  .footer-copy {
    color: var(--parchment-4);
    font-size: 13px;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
  }

  .footer-link {
    color: var(--parchment-4);
    transition: color 150ms ease;
    text-transform: none;
    letter-spacing: 0.5px;
  }
  .footer-link:hover { color: var(--copper); }

  @media (max-width: 700px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
  }
</style>
