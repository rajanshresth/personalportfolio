---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-status">
      <span class="status-dot" aria-hidden="true"></span>
      <span class="label">Open to remote PM roles</span>
    </div>

    <div class="footer-links">
      <a
        href="https://www.linkedin.com/in/rajan10x/"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-link label"
        aria-label="LinkedIn profile"
      >LinkedIn</a>
      <a
        href="https://github.com/rajanshresth"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-link label"
        aria-label="GitHub profile"
      >GitHub</a>
    </div>

    <p class="footer-copy label">
      &copy; {year} Rajan
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--ink-4);
    padding: 32px 0;
    margin-top: auto;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-status {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    animation: pulseDot 2.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  .footer-links {
    display: flex;
    gap: 24px;
  }

  .footer-link {
    color: var(--parchment-4);
    transition: color 150ms ease;
  }
  .footer-link:hover { color: var(--copper); }

  .footer-copy {
    color: var(--parchment-4);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
  }
</style>
