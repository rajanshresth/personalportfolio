---
import CardCluster from './CardCluster.astro';
---

<section class="hero container">
  <div class="hero-content">
    <!-- Eyebrow label -->
    <span class="hero-eyebrow label">
      Industrial Engineering · Data Analysis · Product
    </span>

    <!-- Headline -->
    <h1 class="display hero-headline">
      Engineering systems,<br>
      <em>building products</em>
    </h1>

    <!-- Body -->
    <p class="hero-body">
      I'm Rajan — a B.E. Industrial Engineering student and data
      analyst at Innovative Nepal Group. I use systems thinking and
      data to understand how things break, and product thinking to
      build what fixes them. Working toward a career in Product Management.
    </p>

    <!-- CTAs -->
    <div class="hero-ctas">
      <a href="/work/pm-roadmap-tracker" class="cta-primary">
        View work →
      </a>
      <a href="/writing" class="cta-secondary">
        Read writing →
      </a>
    </div>
  </div>

  <!-- 3D card cluster — desktop only -->
  <div class="hero-cluster">
    <CardCluster />
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 48px;
    padding-top: 80px;
    padding-bottom: 80px;
    border-bottom: 1px solid var(--ink-4);
    min-height: 480px;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 480px;
  }

  /* Staggered fade-up on page load */
  @media (prefers-reduced-motion: no-preference) {
    .hero-eyebrow {
      opacity: 0;
      animation: fadeUp 400ms ease forwards;
      animation-delay: 0ms;
    }
    .hero-headline {
      opacity: 0;
      animation: fadeUp 400ms ease forwards;
      animation-delay: 80ms;
    }
    .hero-body {
      opacity: 0;
      animation: fadeUp 400ms ease forwards;
      animation-delay: 200ms;
    }
    .hero-ctas {
      opacity: 0;
      animation: fadeUp 400ms ease forwards;
      animation-delay: 320ms;
    }
  }

  .hero-eyebrow {
    display: block;
  }

  .hero-headline {
    /* Inherits from .display in global.css */
  }

  .hero-body {
    max-width: 440px;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .cta-primary {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-2);
    padding: 10px 0;
    border-bottom: 1px solid var(--parchment-4);
    transition: color 180ms ease, border-color 180ms ease;
  }
  .cta-primary:hover {
    color: var(--copper);
    border-color: var(--copper);
  }

  .cta-secondary {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-4);
    transition: color 180ms ease;
  }
  .cta-secondary:hover { color: var(--copper); }

  /* Card cluster column */
  .hero-cluster {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Mobile: stack, hide cluster */
  @media (max-width: 767px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 56px;
      padding-bottom: 56px;
      min-height: unset;
      gap: 32px;
    }
    .hero-cluster { display: none; }
    .hero-content { max-width: 100%; }
    .cta-primary, .cta-secondary { font-size: 10px; }
  }
</style>
