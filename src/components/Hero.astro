---
import CardCluster from './CardCluster.astro';
---

<section class="hero container">
  <div class="hero-content">
    <!-- Eyebrow label -->
    <span class="hero-eyebrow label">
      AI & Automation · n8n · Python · Docker
    </span>

    <!-- Headline -->
    <h1 class="display hero-headline">
      Automation that runs<br>
      <em>your revenue engine</em>
    </h1>

    <!-- Body -->
    <p class="hero-body">
      I design and build n8n, Python, and Docker systems for GTM, RevOps,
      and supply chain & logistics teams — pricing engines, lead routing,
      ad allocation, and ops dashboards that replace manual work with
      systems that run on their own.
    </p>

    <!-- CTAs -->
    <div class="hero-ctas">
      <button
        type="button"
        class="btn btn-primary"
        data-magnetic
        data-cal-link="rajan10x/meeting-ai"
        data-cal-namespace="meeting-ai"
        data-cal-config={`{"layout":"month_view"}`}
      >
        Book a call →
      </button>
      <a href="/#work-heading" class="cta-secondary">
        See case studies →
      </a>
    </div>

    <!-- Trust strip -->
    <ul class="hero-trust" role="list">
      <li>
        <img src="https://img.icons8.com/ios-filled/40/718355/clock.png" alt="" width="16" height="16" class="icon" />
        <span>&lt;2 min lead response</span>
      </li>
      <li>
        <img src="https://img.icons8.com/ios-filled/40/718355/shield.png" alt="" width="16" height="16" class="icon" />
        <span>24/7 autonomous uptime</span>
      </li>
      <li>
        <img src="https://img.icons8.com/ios-filled/40/718355/workflow.png" alt="" width="16" height="16" class="icon" />
        <span>n8n · Python · Docker</span>
      </li>
    </ul>
  </div>

  <!-- 3D card cluster — desktop only -->
  <div class="hero-cluster">
    <CardCluster />
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 48px;
    padding-top: 80px;
    padding-bottom: 80px;
    border-bottom: 1px solid var(--ink-4);
    min-height: 480px;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 480px;
  }

  /* Staggered fade-up on page load */
  @media (prefers-reduced-motion: no-preference) {
    .hero-eyebrow {
      opacity: 0;
      animation: fadeUp 400ms ease forwards;
      animation-delay: 0ms;
    }
    .hero-headline {
      opacity: 0;
      animation: fadeUp 400ms ease forwards;
      animation-delay: 80ms;
    }
    .hero-body {
      opacity: 0;
      animation: fadeUp 400ms ease forwards;
      animation-delay: 200ms;
    }
    .hero-ctas {
      opacity: 0;
      animation: fadeUp 400ms ease forwards;
      animation-delay: 320ms;
    }
    .hero-trust {
      opacity: 0;
      animation: fadeUp 400ms ease forwards;
      animation-delay: 420ms;
    }
  }

  .hero-eyebrow {
    display: block;
  }

  .hero-headline {
    /* Inherits from .display in global.css */
  }

  .hero-body {
    max-width: 440px;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .cta-secondary {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-4);
    transition: color 180ms ease;
  }
  .cta-secondary:hover { color: var(--copper); }

  /* Trust strip */
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 20px;
    padding-top: 4px;
  }

  .hero-trust li {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--parchment-4);
  }

  /* Card cluster column */
  .hero-cluster {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Mobile: stack, hide cluster */
  @media (max-width: 767px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 48px;
      padding-bottom: 48px;
      min-height: unset;
      gap: 28px;
    }
    .hero-cluster { display: none; }
    .hero-content { max-width: 100%; gap: 20px; }
    .cta-secondary { font-size: 10px; }
  }

  @media (max-width: 480px) {
    .hero-ctas { flex-direction: column; align-items: flex-start; gap: 14px; }
    .hero-trust { gap: 12px 18px; }
  }
</style>
