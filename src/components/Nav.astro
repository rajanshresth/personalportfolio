---
const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="nav-wrap">
  <nav class="container nav" aria-label="Main navigation">
    <a href="/" class="nav-logo" aria-label="Rajan — home">
      Rajan
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      <li>
        <a href="/work" class:list={['nav-link', { 'nav-link--active': isActive('/work') }]}>
          Work
        </a>
      </li>
      <li>
        <a href="/about" class:list={['nav-link', { 'nav-link--active': isActive('/about') }]}>
          About
        </a>
      </li>
      <li>
        <a href="/pricing" class:list={['nav-link', { 'nav-link--active': isActive('/pricing') }]}>
          Pricing
        </a>
      </li>
    </ul>

    <!-- CTA + mobile toggle -->
    <div class="nav-actions">
      <!-- Persistent conversion CTA -->
      <button
        type="button"
        class="btn btn-primary btn-sm nav-cta"
        data-magnetic
        data-cal-link="rajan10x/meeting-ai"
        data-cal-namespace="meeting-ai"
        data-cal-config={`{"layout":"month_view"}`}
      >
        Book a call
      </button>

      <!-- Mobile hamburger -->
      <button
        class="nav-hamburger"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="nav-mobile"
        id="nav-toggle"
      >
        <img
          src="https://img.icons8.com/ios-filled/50/dbe5e1/menu.png"
          alt=""
          width="20"
          height="20"
          class="nav-hamburger-icon nav-hamburger-icon--open"
        />
        <img
          src="https://img.icons8.com/ios-filled/50/dbe5e1/close-window.png"
          alt=""
          width="18"
          height="18"
          class="nav-hamburger-icon nav-hamburger-icon--close"
          hidden
        />
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <ul class="nav-mobile" id="nav-mobile" hidden role="list">
    <li>
      <button
        type="button"
        class="btn btn-primary btn-sm nav-mobile-cta"
        data-cal-link="rajan10x/meeting-ai"
        data-cal-namespace="meeting-ai"
        data-cal-config={`{"layout":"month_view"}`}
      >
        Book a call
      </button>
    </li>
    <li>
      <a href="/work" class:list={['nav-mobile-link', { 'nav-link--active': isActive('/work') }]}>
        Work
      </a>
    </li>
    <li>
      <a href="/about" class:list={['nav-mobile-link', { 'nav-link--active': isActive('/about') }]}>
        About
      </a>
    </li>
    <li>
      <a href="/pricing" class:list={['nav-mobile-link', { 'nav-link--active': isActive('/pricing') }]}>
        Pricing
      </a>
    </li>
  </ul>
</header>

<script>
  const toggle    = document.getElementById('nav-toggle');
  const menu      = document.getElementById('nav-mobile');
  const openIcon  = toggle?.querySelector('.nav-hamburger-icon--open');
  const closeIcon = toggle?.querySelector('.nav-hamburger-icon--close');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    if (expanded) {
      menu?.setAttribute('hidden', '');
      openIcon?.removeAttribute('hidden');
      closeIcon?.setAttribute('hidden', '');
    } else {
      menu?.removeAttribute('hidden');
      openIcon?.setAttribute('hidden', '');
      closeIcon?.removeAttribute('hidden');
    }
  });
</script>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--ink);
    border-bottom: 1px solid var(--ink-4);
    transition: box-shadow 220ms ease;
  }

  .nav-wrap--scrolled {
    box-shadow: var(--shadow-sm);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    height: 56px;
    transition: height 220ms ease;
  }

  .nav-wrap--scrolled .nav {
    height: 48px;
  }

  /* Logo */
  .nav-logo {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--copper);
  }
  .nav-logo:hover { color: var(--copper); }

  /* Desktop nav links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-4);
    padding-bottom: 2px;
    position: relative;
  }

  /* Underline slide-in on hover */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--copper);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 180ms ease;
  }
  .nav-link:hover { color: var(--parchment-3); }
  .nav-link:hover::after { transform: scaleX(1); }

  /* Active state */
  .nav-link--active {
    color: var(--parchment-2);
    border-bottom: 1px solid var(--copper);
  }
  .nav-link--active::after { display: none; }

  /* CTA + hamburger group */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .nav-cta {
    box-shadow: none;
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    opacity: 0.85;
    transition: opacity 150ms ease;
  }
  .nav-hamburger:hover { opacity: 1; }

  /* Mobile menu */
  .nav-mobile:not([hidden]) {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--ink-4);
    padding: 1rem var(--pad) 1.5rem;
    gap: 0;
  }

  .nav-mobile-cta {
    width: 100%;
    justify-content: center;
    margin-bottom: 14px;
  }

  .nav-mobile-link {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-4);
    display: block;
    padding: 10px 0;
    border-bottom: 1px solid var(--ink-4);
  }
  .nav-mobile-link:last-of-type { border-bottom: none; }
  .nav-mobile-link.nav-link--active { color: var(--parchment-2); }

  /* Responsive */
  @media (max-width: 767px) {
    .nav-links { display: none; }
    .nav-hamburger { display: flex; }
  }

  @media (max-width: 480px) {
    .nav-cta { display: none; }
  }

  @media (min-width: 768px) {
    .nav-mobile { display: none !important; }
  }
</style>
