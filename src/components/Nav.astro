---
const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="nav-wrap">
  <nav class="container nav" aria-label="Main navigation">
    <a href="/" class="nav-logo" aria-label="Rajan — home">
      Rajan<span class="nav-logo-dot" aria-hidden="true">.</span>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      <li>
        <a href="/work/pm-roadmap-tracker" class:list={['nav-link', { 'nav-link--active': isActive('/work') }]}>
          Work
        </a>
      </li>
      <li>
        <a href="/writing" class:list={['nav-link', { 'nav-link--active': isActive('/writing') }]}>
          Writing
        </a>
      </li>
      <li>
        <a href="/about" class:list={['nav-link', { 'nav-link--active': isActive('/about') }]}>
          About
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button
      class="nav-hamburger"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
      id="nav-toggle"
    >
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <ul class="nav-mobile" id="nav-mobile" hidden role="list">
    <li>
      <a href="/work/pm-roadmap-tracker" class:list={['nav-mobile-link', { 'nav-link--active': isActive('/work') }]}>
        Work
      </a>
    </li>
    <li>
      <a href="/writing" class:list={['nav-mobile-link', { 'nav-link--active': isActive('/writing') }]}>
        Writing
      </a>
    </li>
    <li>
      <a href="/about" class:list={['nav-mobile-link', { 'nav-link--active': isActive('/about') }]}>
        About
      </a>
    </li>
  </ul>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu   = document.getElementById('nav-mobile');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    if (expanded) {
      menu?.setAttribute('hidden', '');
    } else {
      menu?.removeAttribute('hidden');
    }
  });
</script>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--ink);
    border-bottom: 1px solid var(--ink-4);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  /* Logo */
  .nav-logo {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.5px;
    color: var(--parchment);
    text-transform: lowercase;
  }
  .nav-logo:hover { color: var(--parchment); }
  .nav-logo-dot { color: var(--copper); }

  /* Desktop nav links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-4);
    padding-bottom: 2px;
    position: relative;
  }

  /* Underline slide-in on hover */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--copper);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 180ms ease;
  }
  .nav-link:hover { color: var(--parchment-3); }
  .nav-link:hover::after { transform: scaleX(1); }

  /* Active state */
  .nav-link--active {
    color: var(--parchment-2);
    border-bottom: 1px solid var(--copper);
  }
  .nav-link--active::after { display: none; }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-hamburger span {
    display: block;
    width: 20px;
    height: 1px;
    background: var(--parchment-3);
    transition: background 150ms ease;
  }
  .nav-hamburger:hover span { background: var(--parchment); }

  /* Mobile menu */
  .nav-mobile:not([hidden]) {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--ink-4);
    padding: 1rem var(--pad) 1.5rem;
    gap: 0;
  }

  .nav-mobile-link {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-4);
    display: block;
    padding: 10px 0;
    border-bottom: 1px solid var(--ink-4);
  }
  .nav-mobile-link:last-of-type { border-bottom: none; }
  .nav-mobile-link.nav-link--active { color: var(--parchment-2); }

  /* Responsive */
  @media (max-width: 767px) {
    .nav-links { display: none; }
    .nav-hamburger { display: flex; }
  }

  @media (min-width: 768px) {
    .nav-mobile { display: none !important; }
  }
</style>
