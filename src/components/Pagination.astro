---
/**
 * Static prev/next pagination for blog post navigation.
 * Used in BlogPost.astro layout.
 */
interface Props {
  prev?: { slug: string; title: string } | null;
  next?: { slug: string; title: string } | null;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="post-nav" aria-label="Post navigation">
    <div class="post-nav-inner">
      {prev ? (
        <a href={`/writing/${prev.slug}`} class="post-nav-link post-nav-link--prev">
          <span class="label">← Previous</span>
          <span class="post-nav-title">{prev.title}</span>
        </a>
      ) : <div />}

      {next ? (
        <a href={`/writing/${next.slug}`} class="post-nav-link post-nav-link--next">
          <span class="label">Next →</span>
          <span class="post-nav-title">{next.title}</span>
        </a>
      ) : <div />}
    </div>
  </nav>
)}

<style>
  .post-nav {
    padding-top: 48px;
    border-top: 1px solid var(--ink-4);
    margin-top: 48px;
  }

  .post-nav-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 6px;
    color: var(--parchment-4);
    transition: color 150ms ease;
  }
  .post-nav-link:hover { color: var(--copper); }

  .post-nav-link--next {
    text-align: right;
    align-items: flex-end;
  }

  .post-nav-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    color: var(--parchment-2);
    line-height: 1.3;
  }
  .post-nav-link:hover .post-nav-title { color: var(--parchment); }

  @media (max-width: 600px) {
    .post-nav-inner {
      grid-template-columns: 1fr;
    }
    .post-nav-link--next {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>
