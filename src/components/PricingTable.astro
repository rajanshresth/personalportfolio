---
const includes = [
  'Full system architecture design',
  'Custom AI pipeline integration',
  'Rigorous security implementation',
];

const retainerFeatures = [
  { icon: 'speed', label: 'Performance tuning' },
  { icon: 'refresh', label: 'Model updates' },
  { icon: 'headset', label: 'Priority support' },
];
---

<div class="pricing-bento">
  <div class="pricing-card pricing-card--fixed" data-spotlight>
    <div class="pricing-card-top">
      <div>
        <span class="pricing-phase label">Phase 1</span>
        <h2 class="pricing-card-title">The Fixed Build</h2>
        <p class="pricing-card-sub">Custom architecture, engineered from the ground up.</p>
      </div>
      <img src="https://img.icons8.com/ios-filled/50/a1d1bf/blueprint.png" alt="" width="36" height="36" class="pricing-card-icon" />
    </div>

    <div class="pricing-fixed-grid">
      <div>
        <h3 class="pricing-subhead label">Includes</h3>
        <ul class="pricing-includes" role="list">
          {includes.map(item => (
            <li>
              <img src="https://img.icons8.com/ios-filled/40/d5ffee/checkmark.png" alt="" width="14" height="14" class="icon" />
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div class="pricing-fixed-cost">
        <span class="label">Starting at</span>
        <span class="pricing-quote">Custom Quote</span>
        <button
          type="button"
          class="btn btn-primary pricing-request-btn"
          data-magnetic
          data-cal-link="rajan10x/meeting-ai"
          data-cal-namespace="meeting-ai"
          data-cal-config={`{"layout":"month_view"}`}
        >
          Request Quote
        </button>
      </div>
    </div>
  </div>

  <div class="pricing-card pricing-card--retainer" data-spotlight>
    <div>
      <span class="pricing-phase label pricing-phase--secondary">Phase 2</span>
      <h2 class="pricing-card-title pricing-card-title--sm">Retainer</h2>
      <p class="pricing-card-sub">Ongoing optimization & scaling.</p>
    </div>

    <ul class="pricing-retainer-list" role="list">
      {retainerFeatures.map(f => (
        <li>
          <img src={`https://img.icons8.com/ios-filled/40/a1d1bf/${f.icon}.png`} alt="" width="16" height="16" class="icon" />
          {f.label}
        </li>
      ))}
    </ul>

    <div class="pricing-retainer-note">
      Available post-launch
    </div>
  </div>
</div>

<style>
  .pricing-bento {
    display: grid;
    grid-template-columns: 8fr 4fr;
    gap: 24px;
    align-items: stretch;
  }

  .pricing-card {
    background: var(--ink-2);
    border: 1px solid var(--ink-4);
    border-radius: 8px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    transition: border-color 200ms ease;
  }
  .pricing-card:hover { border-color: var(--copper); }

  .pricing-card--fixed {
    justify-content: space-between;
    gap: 40px;
  }

  .pricing-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
  }

  .pricing-phase {
    display: inline-block;
    background: var(--ink);
    border: 1px solid var(--ink-4);
    border-radius: 3px;
    padding: 4px 10px;
    color: var(--copper);
    margin-bottom: 16px;
  }
  .pricing-phase--secondary { color: var(--parchment-3); }

  .pricing-card-title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 600;
    color: var(--parchment);
    margin-bottom: 8px;
  }
  .pricing-card-title--sm { font-size: 22px; }

  .pricing-card-sub {
    font-size: 14px;
  }

  .pricing-card-icon {
    flex-shrink: 0;
    opacity: 0.8;
  }

  .pricing-fixed-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: end;
  }

  .pricing-subhead {
    border-bottom: 1px solid var(--ink-4);
    padding-bottom: 10px;
    margin-bottom: 16px;
  }

  .pricing-includes {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .pricing-includes li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--parchment-3);
  }
  .pricing-includes .icon { margin-top: 3px; flex-shrink: 0; }

  .pricing-fixed-cost {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pricing-quote {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 600;
    color: var(--parchment);
    margin-bottom: 10px;
  }

  .pricing-request-btn {
    width: fit-content;
  }

  /* Retainer card */
  .pricing-card--retainer {
    justify-content: space-between;
    gap: 24px;
  }

  .pricing-retainer-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 12px;
  }
  .pricing-retainer-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: var(--parchment-3);
    padding: 12px 0;
    border-bottom: 1px solid var(--ink-4);
  }
  .pricing-retainer-list li:last-child { border-bottom: none; }

  .pricing-retainer-note {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.5px;
    color: var(--parchment-4);
    background: var(--ink);
    border: 1px solid var(--ink-4);
    border-radius: 4px;
    padding: 14px;
  }

  @media (max-width: 900px) {
    .pricing-bento {
      grid-template-columns: 1fr;
    }
    .pricing-fixed-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  @media (max-width: 600px) {
    .pricing-card { padding: 24px; }
  }
</style>
