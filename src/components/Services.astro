---
const services = [
  {
    name: 'GTM Automation',
    desc: 'Architecting lead routing, enrichment pipelines, and personalized outreach sequences at scale. Connecting CRMs, intent data providers, and execution channels.',
    icon: 'rocket',
  },
  {
    name: 'RevOps Automation',
    desc: 'Synchronizing billing systems, contracting platforms, and CRM data. Ensuring revenue data integrity and automating commission calculations.',
    icon: 'synchronize',
  },
  {
    name: 'Supply Chain & Logistics',
    desc: 'Building bespoke inventory tracking, dynamic routing alerts, and vendor API integrations. Reducing manual data entry across fragmented logistics tools.',
    icon: 'truck',
  },
];
---

<div class="services-grid" data-reveal-group>
  {services.map(s => (
    <div class="service-card" data-spotlight>
      <div class="service-icon">
        <img
          src={`https://img.icons8.com/ios-filled/40/a1d1bf/${s.icon}.png`}
          alt=""
          width="22"
          height="22"
        />
      </div>
      <h3 class="service-name">{s.name}</h3>
      <p class="service-desc">{s.desc}</p>
    </div>
  ))}
</div>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 32px;
    background-color: var(--ink);
    border: 1px solid var(--ink-4);
    border-radius: 8px;
    transition: border-color 200ms ease, transform 200ms ease;
  }
  .service-card:hover {
    transform: translateY(-4px);
    border-color: var(--copper);
  }

  .service-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--ink-3);
    border: 1px solid var(--ink-4);
    margin-bottom: 12px;
    transition: background 200ms ease, border-color 200ms ease;
  }
  .service-card:hover .service-icon {
    background: var(--copper);
    border-color: var(--copper);
  }

  .service-name {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 600;
    color: var(--parchment);
  }

  .service-desc {
    font-size: 14px;
    line-height: 1.65;
    flex-grow: 1;
  }

  @media (max-width: 700px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
