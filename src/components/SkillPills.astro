---
const highlighted = ['Product Management', 'Data Analysis', 'SQL'];

const standard = [
  'JavaScript', 'TypeScript', 'Python', 'AI',
  'Google Sheets', 'Apps Script', 'Excel',
  'Figma', 'Agile', 'User Research', 'PRD Writing',
];
---

<div class="skills-wrap">
  <div class="skill-row">
    {highlighted.map(skill => (
      <span class="skill-pill skill-pill--highlight">{skill}</span>
    ))}
    {standard.map(skill => (
      <span class="skill-pill">{skill}</span>
    ))}
  </div>
</div>

<style>
  .skills-wrap {
    /* no extra wrapper needed */
  }

  .skill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--parchment-4);
    border: 1px solid var(--ink-4);
    border-radius: 2px;
    padding: 4px 10px;
    background: transparent;
    transition: background 150ms ease, color 150ms ease;
    cursor: default;
  }
  .skill-pill:hover {
    background: var(--ink-3);
    color: var(--parchment-3);
  }

  .skill-pill--highlight {
    color: var(--parchment-2);
    border-color: var(--ink-3);
    background: var(--ink-3);
  }
  .skill-pill--highlight:hover {
    background: var(--ink-4);
    color: var(--parchment);
  }
</style>
