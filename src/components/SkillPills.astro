---
const categories = [
  {
    name: 'Automation & Orchestration',
    items: ['n8n (self-hosted, Docker)', 'Make.com', 'Zapier', 'Google Apps Script', 'Cloudflare Workers'],
    icon: 'workflow',
  },
  {
    name: 'AI / LLM Engineering',
    items: ['Claude API (tool use, structured outputs)', 'OpenAI API', 'RAG pipelines', 'pgvector', 'prompt engineering', 'agentic workflows'],
    icon: 'robot',
  },
  {
    name: 'Integrations & Data',
    items: ['HubSpot API', 'Apollo.io API', 'Airtable', 'Google Sheets', 'Supabase', 'Google Data Studio', 'SQL'],
    icon: 'puzzle',
  },
  {
    name: 'Programming & Infrastructure',
    items: ['Python (requests, httpx, async/await)', 'PostgreSQL/Redis', 'Railway', 'Cloudflare Pages', 'Apify Actors', 'Docker', 'GitHub'],
    icon: 'code',
  },
];
---

<div class="skills-wrap" data-reveal-group>
  {categories.map(category => (
    <div class="skill-category">
      <span class="skill-category-label label">
        <img
          src={`https://img.icons8.com/ios-filled/40/718355/${category.icon}.png`}
          alt=""
          width="14"
          height="14"
          class="icon"
        />
        {category.name}
      </span>
      <div class="skill-row">
        {category.items.map(skill => (
          <span class="skill-pill">{skill}</span>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .skills-wrap {
    width: 80%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .skill-category-label {
    display: flex;
    align-items: center;
    gap: 7px;
    color: var(--copper);
    margin-bottom: 10px;
  }

  .skill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--parchment-4);
    border: 1px solid var(--ink-4);
    border-radius: 2px;
    padding: 4px 10px;
    background: transparent;
    transition: background 150ms ease, color 150ms ease;
    cursor: default;
  }
  .skill-pill:hover {
    background: var(--ink-3);
    color: var(--parchment-3);
  }

  @media (max-width: 600px) {
    .skills-wrap {
      width: 100%;
    }
  }
</style>
