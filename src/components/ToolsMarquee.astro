---
const tools = [
  'Python', 'n8n', 'Docker', 'AWS / GCP', 'REST / GraphQL',
];
---

<div class="tools-marquee">
  <div class="marquee">
    <div class="marquee-track">
      {tools.map(t => <span class="marquee-item">{t}</span>)}
    </div>
    <div class="marquee-track" aria-hidden="true">
      {tools.map(t => <span class="marquee-item">{t}</span>)}
    </div>
  </div>
</div>

<style>
  .tools-marquee {
    border-bottom: 1px solid var(--ink-4);
    padding: 18px 0;
  }

  /* Override the shared marquee gap — spacing here comes from the
     item's own padding so the bullet separator can sit centered in it. */
  .marquee-track {
    gap: 0;
    padding-right: 0;
  }

  .marquee-item {
    position: relative;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-4);
    white-space: nowrap;
    padding-right: 44px;
    transition: color 200ms ease;
  }
  .marquee-item:hover { color: var(--copper); }

  .marquee-item::after {
    content: '\2022';
    position: absolute;
    right: 18px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ink-4);
  }
</style>
