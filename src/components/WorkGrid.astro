---
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'work'>[];
}

const { projects } = Astro.props;
const sorted = projects.sort((a, b) => a.data.order - b.data.order);
---

<section class="work-section">
  <div class="work-header">
    <span class="section-label">Work</span>
    <h2 class="work-title">Selected projects</h2>
  </div>

  <div class="work-grid">
    {sorted.map(project => (
      <a href={`/work/${project.slug}`} class="work-card">
        <div class="work-card-top">
          <div class="work-card-meta">
            <span class="work-stage">{project.data.stage}</span>
          </div>
          <h3 class="work-card-title">{project.data.title}</h3>
          <p class="work-card-desc">{project.data.description}</p>
        </div>
        <div class="work-card-bottom">
          <div class="work-card-tags">
            {project.data.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <span class="work-card-cta">View project →</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .work-section {
    padding-block: 5rem 0;
  }

  .work-header {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .work-title {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--text);
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  /* Work card */
  .work-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.75rem;
    transition: transform var(--t), box-shadow var(--t), border-color var(--t);
    min-height: 220px;
  }

  .work-card:hover {
    transform: translate3d(0, -4px, 0);
    box-shadow: var(--shadow-lift);
    border-color: var(--accent);
  }

  .work-card-top {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .work-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .work-stage {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
  }

  .work-card-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    color: var(--text);
    line-height: 1.2;
    transition: color var(--t);
  }

  .work-card:hover .work-card-title {
    color: var(--secondary);
  }

  .work-card-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
  }

  .work-card-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .work-card-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .work-card-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    flex-shrink: 0;
    transition: color var(--t);
  }

  .work-card:hover .work-card-cta {
    color: var(--secondary);
  }

  /* Mobile */
  @media (max-width: 600px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
