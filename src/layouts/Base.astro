---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?:       string;
  description?: string;
  image?:       string;   // absolute URL or path — used for og:image
  imageAlt?:    string;
  type?:        'website' | 'article';
  publishedAt?: Date;
  tags?:        string[];
}

const {
  title       = 'Rajan Shrestha — AI & Automation for GTM, RevOps & Supply Chain',
  description = 'I build n8n, Python, and Docker automation systems for GTM, RevOps, and supply chain & logistics teams — pricing engines, lead routing, ad allocation, and ops dashboards that run without you.',
  image,
  imageAlt    = 'Rajan Shrestha — AI & Automation Consultant',
  type        = 'website',
  publishedAt,
  tags        = [],
} = Astro.props;

const siteUrl   = Astro.site ?? new URL('https://rajanbuilds.com');
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage   = image
  ? (image.startsWith('http') ? image : new URL(image, siteUrl).href)
  : new URL('/og/default.png', siteUrl).href;

// WebSite + Person structured data (homepage only, via type=website)
const websiteSchema = {
  '@context':  'https://schema.org',
  '@type':     'WebSite',
  name:        'Rajan Shrestha',
  url:         siteUrl.href,
  description: 'AI & automation consulting — n8n, Python, and Docker systems for GTM, RevOps, and supply chain & logistics teams.',
  author: {
    '@type': 'Person',
    name:    'Rajan Shrestha',
    url:     new URL('/about', siteUrl).href,
    jobTitle: 'AI & Automation Consultant',
    knowsAbout: ['n8n', 'Python', 'Docker', 'GTM Automation', 'RevOps', 'Supply Chain & Logistics'],
    sameAs: [
      'https://www.linkedin.com/in/rajan10x/',
      'https://github.com/rajanshresth',
    ],
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0c1513" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={canonical} />

    <!-- Flag JS support before paint, so scroll-reveal CSS only hides
         content when the motion script is actually going to run it. -->
    <script is:inline>document.documentElement.classList.add('js');</script>

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Rajan Shrestha" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Rajan Shrestha" />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content="en_US" />

    <!-- Article-specific Open Graph -->
    {type === 'article' && publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}
    {type === 'article' && tags.map(tag => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/og/default.png" />

    <!-- Structured data: WebSite + Person -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://img.icons8.com" />

    <!-- Inter + JetBrains Mono via Google Fonts -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />

    <!-- Cal floating-popup embed code begins -->
    <script type="text/javascript">
      (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
      Cal("init", "meeting-ai", {origin:"https://app.cal.com"});
      Cal.config = Cal.config || {};
      Cal.config.forwardQueryParams = true;

      Cal.ns["meeting-ai"]("floatingButton", {"calLink":"rajan10x/meeting-ai","config":{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}});
      Cal.ns["meeting-ai"]("ui", {"hideEventTypeDetails":false,"layout":"month_view"});
    </script>
    <!-- Cal floating-popup embed code ends -->
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import '../scripts/motion.ts';
    </script>
  </body>
</html>
