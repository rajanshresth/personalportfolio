---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?:       string;
  description?: string;
  image?:       string;   // absolute URL or path — used for og:image
  imageAlt?:    string;
  type?:        'website' | 'article';
  publishedAt?: Date;
  tags?:        string[];
}

const {
  title       = 'Rajan Shrestha — Industrial Engineering & Product',
  description = 'B.E. Industrial Engineering student and data analyst at Innovative Nepal Group. Applying systems thinking toward a career in Product Management.',
  image,
  imageAlt    = 'Rajan Shrestha — portfolio',
  type        = 'website',
  publishedAt,
  tags        = [],
} = Astro.props;

const siteUrl   = Astro.site ?? new URL('https://rajanbuilds.com');
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage   = image
  ? (image.startsWith('http') ? image : new URL(image, siteUrl).href)
  : new URL('/og/default.png', siteUrl).href;

// WebSite + Person structured data (homepage only, via type=website)
const websiteSchema = {
  '@context':  'https://schema.org',
  '@type':     'WebSite',
  name:        'Rajan Shrestha',
  url:         siteUrl.href,
  description: 'Portfolio of Rajan Shrestha — industrial engineering, data analysis, and product management.',
  author: {
    '@type': 'Person',
    name:    'Rajan Shrestha',
    url:     new URL('/about', siteUrl).href,
    jobTitle: 'Data Analyst & Aspiring Product Manager',
    worksFor: { '@type': 'Organization', name: 'Innovative Nepal Group' },
    alumniOf: { '@type': 'CollegeOrUniversity', name: 'T.U. I.O.E. Thapathali Campus' },
    sameAs: [
      'https://www.linkedin.com/in/rajan10x/',
      'https://github.com/rajanshresth',
    ],
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f0e0b" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={canonical} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Rajan Shrestha" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Rajan Shrestha" />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content="en_US" />

    <!-- Article-specific Open Graph -->
    {type === 'article' && publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}
    {type === 'article' && tags.map(tag => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/og/default.png" />

    <!-- Structured data: WebSite + Person -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" />

    <!-- Cormorant Garamond + Geist Mono via Google Fonts -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Geist+Mono:wght@400;500&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Switzer via Fontshare -->
    <link
      href="https://api.fontshare.com/v2/css?f[]=switzer@300,400,500&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
