---
import Base from './Base.astro';
import Pagination from '../components/Pagination.astro';

interface Props {
  title:       string;
  description: string;
  publishedAt: Date;
  tags:        string[];
  headings:    { depth: number; slug: string; text: string }[];
  wordCount:   number;
  image?:      string;
  imageAlt?:   string;
  prev?:       { slug: string; title: string } | null;
  next?:       { slug: string; title: string } | null;
}

const {
  title,
  description,
  publishedAt,
  tags,
  headings,
  wordCount,
  image,
  imageAlt,
  prev,
  next,
} = Astro.props;

const readTime = Math.max(1, Math.ceil(wordCount / 200));

const dateStr = publishedAt.toLocaleDateString('en-US', {
  year:  'numeric',
  month: 'long',
  day:   'numeric',
});

// Only h2 + h3 for TOC
const tocItems = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<Base
  title={`${title} — Rajan`}
  description={description}
  image={image}
  imageAlt={imageAlt ?? title}
  type="article"
  publishedAt={publishedAt}
  tags={tags}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "datePublished": publishedAt.toISOString(),
    "author": {
      "@type": "Person",
      "name": "Rajan Shrestha",
      "url": "https://rajanbuilds.com/about"
    },
    "publisher": {
      "@type": "Person",
      "name": "Rajan Shrestha",
      "url": "https://rajanbuilds.com"
    },
    ...(image && { "image": image }),
    "keywords": tags.join(", "),
  })} />
  <div class="post-layout container">
    <!-- Sticky breadcrumb -->
    <a href="/writing" class="breadcrumb label">← Writing</a>

    <div class="post-grid">
      <!-- Article -->
      <article class="post-article">
        <!-- Cover image -->
        {image && (
          <div class="post-cover">
            <img src={image} alt={imageAlt ?? title} loading="lazy" decoding="async" />
          </div>
        )}

        <!-- Header -->
        <header class="post-header">
          <div class="post-meta">
            <time class="label" datetime={publishedAt.toISOString()}>{dateStr}</time>
            <span class="label post-meta-sep">·</span>
            <span class="label">{readTime} min read</span>
          </div>

          <h1 class="post-title">{title}</h1>

          <div class="post-tags">
            {tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </header>

        <!-- Body -->
        <div class="prose">
          <slot />
        </div>

        <!-- Prev / Next -->
        <Pagination prev={prev} next={next} />
      </article>

      <!-- TOC sidebar — desktop only -->
      {tocItems.length > 0 && (
        <aside class="toc-sidebar" aria-label="Table of contents">
          <nav class="toc" id="toc">
            <span class="label toc-heading">Contents</span>
            <ol class="toc-list" role="list">
              {tocItems.map(h => (
                <li class:list={['toc-item', { 'toc-item--h3': h.depth === 3 }]}>
                  <a href={`#${h.slug}`} class="toc-link label" data-heading={h.slug}>
                    {h.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )}
    </div>
  </div>
</Base>

<script>
  // Highlight active TOC link as user scrolls
  const links = document.querySelectorAll('.toc-link');
  if (links.length > 0) {
    const headingEls = Array.from(links).map(l =>
      document.getElementById(l.dataset.heading)
    ).filter(Boolean);

    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            links.forEach(l => l.classList.remove('toc-link--active'));
            const active = document.querySelector(`.toc-link[data-heading="${entry.target.id}"]`);
            active?.classList.add('toc-link--active');
          }
        });
      },
      { rootMargin: '-10% 0px -80% 0px', threshold: 0 }
    );

    headingEls.forEach(el => observer.observe(el));
  }
</script>

<style>
  .post-layout {
    padding-top: 48px;
    padding-bottom: 80px;
  }

  .breadcrumb {
    display: inline-block;
    margin-bottom: 40px;
    color: var(--parchment-4);
    transition: color 150ms ease;
  }
  .breadcrumb:hover { color: var(--copper); }

  .post-grid {
    display: grid;
    grid-template-columns: 1fr 200px;
    gap: 64px;
    align-items: start;
  }

  /* Cover image */
  .post-cover {
    margin-bottom: 40px;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--ink-4);
  }
  .post-cover img {
    width: 100%;
    height: auto;
    display: block;
    max-height: 420px;
    object-fit: cover;
  }

  /* Article */
  .post-header {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--ink-4);
    margin-bottom: 40px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .post-meta-sep { color: var(--ink-4); }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4.5vw, 44px);
    font-weight: 700;
    color: var(--parchment);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  /* Prose styles */
  .prose {
    color: var(--parchment-2);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.85;
  }

  .prose p {
    font-size: 15px;
    line-height: 1.85;
    color: var(--parchment-2);
    margin-bottom: 1.4em;
  }

  .prose h2 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 600;
    color: var(--parchment);
    line-height: 1.2;
    margin-top: 2.2em;
    margin-bottom: 0.7em;
  }

  .prose h3 {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 500;
    color: var(--parchment-2);
    line-height: 1.4;
    margin-top: 1.8em;
    margin-bottom: 0.5em;
  }

  .prose a { color: var(--copper); }
  .prose a:hover { opacity: 0.8; }

  .prose ul,
  .prose ol {
    padding-left: 1.5em;
    margin-bottom: 1.4em;
  }
  .prose ul { list-style: disc; }
  .prose ol { list-style: decimal; }
  .prose li { margin-bottom: 0.4em; }

  .prose code:not(pre code) {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 400;
    background: var(--ink-3);
    color: var(--parchment-2);
    padding: 2px 6px;
    border-radius: 2px;
  }

  .prose pre {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--ink-2);
    border: 1px solid var(--ink-4);
    border-radius: 4px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.4em;
  }
  .prose pre code {
    background: none;
    padding: 0;
    border-radius: 0;
    color: var(--parchment-2);
  }

  .prose blockquote {
    border-left: 2px solid var(--ink-4);
    padding-left: 1.25rem;
    margin: 1.4em 0;
    font-style: italic;
    color: var(--parchment-3);
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--ink-4);
    margin: 2.5em 0;
  }

  /* Images in prose */
  .prose img {
    width: 100%;
    height: auto;
    border-radius: 3px;
    border: 1px solid var(--ink-4);
    margin: 1.8em 0;
    display: block;
  }

  .prose figure {
    margin: 2em 0;
  }
  .prose figure img {
    margin: 0 0 0.6em;
  }
  .prose figcaption {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--parchment-4);
    text-align: center;
  }

  /* TOC sidebar */
  .toc-sidebar {
    position: sticky;
    top: 80px;
  }

  .toc {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .toc-heading {
    display: block;
    letter-spacing: 1.5px;
    margin-bottom: 4px;
  }

  .toc-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .toc-item { }
  .toc-item--h3 { padding-left: 12px; }

  .toc-link {
    display: block;
    padding: 4px 0;
    color: var(--parchment-4);
    text-transform: none;
    letter-spacing: 0;
    font-size: 11px;
    line-height: 1.4;
    transition: color 150ms ease;
    border-left: 1px solid transparent;
    padding-left: 8px;
  }
  .toc-link:hover { color: var(--parchment-3); }
  .toc-link--active {
    color: var(--parchment-2);
    border-left-color: var(--copper);
  }

  /* Mobile */
  @media (max-width: 767px) {
    .post-layout { padding-top: 32px; padding-bottom: 56px; }
    .post-grid { grid-template-columns: 1fr; gap: 0; }
    .toc-sidebar { display: none; }
    .breadcrumb { margin-bottom: 28px; }
    .post-cover { margin-bottom: 28px; }
    .post-cover img { max-height: 260px; }
    .post-title { letter-spacing: -0.5px; }
  }
</style>
