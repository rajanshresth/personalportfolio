---
import Base    from './Base.astro';
import Pagination from '../components/Pagination.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post:     CollectionEntry<'writing'>;
  headings: { depth: number; slug: string; text: string }[];
  prev?:    { slug: string; title: string } | null;
  next?:    { slug: string; title: string } | null;
}

const { post, headings, prev, next } = Astro.props;

const { title, description, publishedAt, tags } = post.data;

const dateStr   = publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const wordCount = post.body ? post.body.split(/\s+/).length : 0;
const readTime  = Math.max(1, Math.ceil(wordCount / 200));

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<Base title={`${title} — Rajan`} description={description}>
  <div class="post-layout container">

    <!-- Breadcrumb -->
    <a href="/writing" class="post-breadcrumb">← Writing</a>

    <div class="post-columns">

      <!-- Main content -->
      <article class="post-article" aria-labelledby="post-title">

        <!-- Header -->
        <header class="post-header">
          <div class="post-meta-row">
            <time datetime={publishedAt.toISOString()} class="post-date">{dateStr}</time>
            <span class="post-readtime">{readTime} min read</span>
          </div>

          <h1 class="post-title" id="post-title">{title}</h1>
          <p class="post-lead">{description}</p>

          <div class="post-tags">
            {tags.map(tag => (
              <a href={`/writing?tag=${encodeURIComponent(tag)}`} class="tag">{tag}</a>
            ))}
          </div>
        </header>

        <hr class="divider post-divider" />

        <!-- Body -->
        <div class="prose">
          <slot />
        </div>

        <!-- Prev / Next -->
        <Pagination prev={prev} next={next} />

      </article>

      <!-- Table of contents (desktop sidebar) -->
      {tocHeadings.length > 1 && (
        <aside class="post-toc" aria-label="Table of contents">
          <span class="toc-label section-label">Contents</span>
          <nav>
            <ol class="toc-list">
              {tocHeadings.map(h => (
                <li class:list={['toc-item', `toc-depth-${h.depth}`]}>
                  <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )}

    </div>
  </div>
</Base>

<script>
  // Highlight active TOC link on scroll via IntersectionObserver
  const tocLinks = document.querySelectorAll('.toc-link');
  const headings = document.querySelectorAll('.prose h2, .prose h3');

  if (tocLinks.length && headings.length) {
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          tocLinks.forEach(link => {
            const isActive = link.getAttribute('href') === `#${id}`;
            link.classList.toggle('toc-link--active', isActive);
          });
        }
      });
    }, { rootMargin: '-15% 0px -80% 0px' });

    headings.forEach(h => observer.observe(h));
  }
</script>

<style>
  /* ── Layout ── */
  .post-layout {
    padding-top: 2.5rem;
    padding-bottom: 5rem;
  }

  .post-breadcrumb {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 2rem;
    transition: color var(--t);
  }

  .post-breadcrumb:hover {
    color: var(--secondary);
  }

  .post-columns {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 4rem;
    align-items: start;
  }

  /* ── Article ── */
  .post-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .post-meta-row {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .post-date,
  .post-readtime {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    color: var(--text);
    line-height: 1.15;
    font-weight: 400;
  }

  .post-lead {
    font-size: 16px;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.7;
    max-width: 58ch;
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .post-divider {
    margin-block: 2rem;
  }

  /* ── Prose typography ── */
  .prose {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.85;
    color: var(--text);
    max-width: 68ch;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 400;
    color: var(--text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .prose :global(h3) {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 500;
    color: var(--secondary);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
    color: color-mix(in srgb, var(--text) 85%, var(--muted));
  }

  .prose :global(a) {
    color: var(--secondary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--t);
  }

  .prose :global(a:hover) {
    border-color: var(--secondary);
  }

  .prose :global(strong) {
    font-weight: 500;
    color: var(--text);
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 1rem 0 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .prose :global(ul) { list-style: disc; }
  .prose :global(ol) { list-style: decimal; }

  .prose :global(li) {
    color: color-mix(in srgb, var(--text) 85%, var(--muted));
    padding-left: 0.25rem;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--secondary);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    color: var(--muted);
    font-style: italic;
  }

  .prose :global(code):not(:global(pre code)) {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--secondary);
    background: var(--surface);
    padding: 2px 6px;
    border-radius: 3px;
    border: 1px solid var(--border);
  }

  .prose :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose :global(pre code) {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text);
    background: none;
    padding: 0;
    border: none;
    border-radius: 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  .prose :global(img) {
    border-radius: 6px;
    border: 1px solid var(--border);
    margin: 1.5rem 0;
  }

  /* ── Table of Contents (sidebar) ── */
  .post-toc {
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-height: calc(100vh - var(--nav-height) - 4rem);
    overflow-y: auto;
  }

  .toc-label {
    margin-bottom: 0.25rem;
  }

  .toc-list {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    line-height: 1.4;
  }

  .toc-depth-3 {
    padding-left: 0.85rem;
  }

  .toc-link {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    color: var(--muted);
    display: block;
    padding: 3px 0;
    transition: color var(--t);
    border-left: 2px solid transparent;
    padding-left: 8px;
    margin-left: -10px;
  }

  .toc-link:hover,
  .toc-link--active {
    color: var(--secondary);
    border-left-color: var(--secondary);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .post-columns {
      grid-template-columns: 1fr;
    }

    .post-toc {
      display: none;
    }
  }
</style>
