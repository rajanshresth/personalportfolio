---
import Base from '../layouts/Base.astro';
import SkillPills from '../components/SkillPills.astro';
---

<Base
  title="About — Rajan"
  description="B.E. Industrial Engineering student and data analyst at Innovative Nepal Group, building toward a career in Product Management."
>
  <div class="container about-layout">
    <!-- Page header -->
    <header class="about-header section">
      <span class="label">About</span>
      <h1 class="about-title">
        Engineering background,<br>
        <em>product ambitions</em>
      </h1>
    </header>

    <div class="about-grid section">
      <!-- Main content -->
      <main class="about-body">
        <section class="about-section">
          <h2>Background</h2>
          <p>
            I'm Rajan — currently studying B.E. Industrial Engineering at T.U. I.O.E.
            Thapathali Campus in Nepal. Alongside my studies, I work as a data analyst
            at Innovative Nepal Group, where I build dashboards and tooling to track
            operational performance.
          </p>
          <p>
            Industrial engineering gave me a framework for thinking about systems: how
            inputs become outputs, where waste hides, and how small process changes
            cascade into large results. I use that same lens when I think about products.
          </p>
        </section>

        <section class="about-section">
          <h2>What I'm working toward</h2>
          <p>
            My goal is a career in Product Management — specifically remote PM roles
            where I can apply systems thinking and data analysis to help teams build
            things people actually need.
          </p>
          <p>
            To get there, I'm building a foundation in product craft: writing PRDs,
            studying user research methods, learning to frame engineering trade-offs as
            product decisions, and documenting the process publicly on this site.
          </p>
        </section>

        <section class="about-section">
          <h2>Skills</h2>
          <SkillPills />
        </section>

        <section class="about-section">
          <h2>Education</h2>
          <p>
            B.E. Industrial Engineering — T.U. I.O.E. Thapathali Campus, Nepal
          </p>
        </section>

        <section class="about-section">
          <h2>Get in touch</h2>
          <p>
            I'm open to remote PM roles, freelance data work, and conversations about
            product, systems, or Nepal's tech scene.
          </p>
          <a
            href="https://www.linkedin.com/in/rajan10x/"
            target="_blank"
            rel="noopener noreferrer"
            class="about-cta label"
          >
            Connect on LinkedIn →
          </a>
        </section>
      </main>

      <!-- Sidebar -->
      <aside class="about-sidebar">
        <div class="sidebar-card">
          <dl class="sidebar-list">
            <div class="sidebar-item">
              <dt class="label">Currently</dt>
              <dd>Data Analyst @ ING, Nepal</dd>
            </div>
            <div class="sidebar-item">
              <dt class="label">Studying</dt>
              <dd>B.E. IE @ T.U. I.O.E. Thapathali</dd>
            </div>
            <div class="sidebar-item">
              <dt class="label">Goal</dt>
              <dd>Remote PM roles</dd>
            </div>
            <div class="sidebar-item">
              <dt class="label">Location</dt>
              <dd>Nepal</dd>
            </div>
          </dl>

          <div class="sidebar-links">
            <a
              href="https://www.linkedin.com/in/rajan10x/"
              target="_blank"
              rel="noopener noreferrer"
              class="sidebar-link label"
            >LinkedIn</a>
            <a
              href="https://github.com/rajanshresth"
              target="_blank"
              rel="noopener noreferrer"
              class="sidebar-link label"
            >GitHub</a>
            <a
              href="https://youtube.com/@rajanshresth"
              target="_blank"
              rel="noopener noreferrer"
              class="sidebar-link label"
            >YouTube</a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Base>

<style>
  .about-layout {
    padding-bottom: 80px;
  }

  .about-header {
    padding-top: 64px;
  }

  .label {
    display: block;
    margin-bottom: 16px;
  }

  .about-title {
    font-family: var(--font-display);
    font-size: clamp(30px, 5vw, 48px);
    font-weight: 400;
    color: var(--parchment);
    line-height: 1.08;
    letter-spacing: -1px;
  }
  .about-title em {
    font-style: italic;
    color: var(--parchment-2);
  }

  /* Two-column grid */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 64px;
    align-items: start;
  }

  /* Main body */
  .about-section {
    margin-bottom: 48px;
  }
  .about-section:last-child { margin-bottom: 0; }

  .about-section h2 {
    margin-bottom: 16px;
  }

  .about-section p {
    margin-bottom: 1em;
    font-size: 14px;
  }
  .about-section p:last-of-type { margin-bottom: 0; }

  .about-cta {
    display: inline-block;
    margin-top: 16px;
    color: var(--copper);
    transition: opacity 150ms ease;
  }
  .about-cta:hover { color: var(--copper); opacity: 0.75; }

  /* Sidebar */
  .about-sidebar {
    position: sticky;
    top: 80px;
  }

  .sidebar-card {
    background: var(--ink-2);
    border: 1px solid var(--ink-4);
    border-radius: 3px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sidebar-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .sidebar-item dt {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-4);
    margin-bottom: 3px;
    display: block;
  }

  .sidebar-item dd {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--parchment-2);
    line-height: 1.4;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 16px;
    border-top: 1px solid var(--ink-4);
  }

  .sidebar-link {
    color: var(--parchment-4);
    transition: color 150ms ease;
  }
  .sidebar-link:hover { color: var(--copper); }

  /* Mobile */
  @media (max-width: 767px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .about-sidebar {
      position: static;
      order: -1;
    }
  }
</style>
