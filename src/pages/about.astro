---
import Base from '../layouts/Base.astro';
import SkillPills from '../components/SkillPills.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type':    'Person',
  name:       'Rajan Shrestha',
  url:        'https://rajanbuilds.com/about',
  jobTitle:   'AI & Automation Consultant',
  description: 'AI automation consultant building n8n, Python, and Docker systems for GTM, RevOps, and supply chain & logistics teams.',
  knowsAbout: ['n8n', 'Python', 'Docker', 'GTM Automation', 'RevOps', 'Supply Chain & Logistics'],
  address:    { '@type': 'PostalAddress', addressCountry: 'NP' },
  sameAs: [
    'https://www.linkedin.com/in/rajan10x/',
    'https://github.com/rajanshresth',
  ],
};
---

<Base
  title="About — Rajan Shrestha"
  description="AI automation consultant building n8n, Python, and Docker systems for GTM, RevOps, and supply chain & logistics teams."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <div class="container about-layout">
    <!-- Page header -->
    <header class="about-header section">
      <span class="label">About</span>
      <h1 class="about-title">
        Engineering background,<br>
        <em>automation focus</em>
      </h1>
    </header>

    <div class="about-grid section">
      <!-- Main content -->
      <main class="about-body">
        <section class="about-section" data-reveal>
          <h2>Background</h2>
          <p>
            I'm Rajan — an industrial engineer by training, which means I think in
            systems before I think in tools: inputs, outputs, bottlenecks, and where
            a process quietly leaks time or money. I started applying that lens to
            data and operations work, and it kept leading to the same conclusion —
            most businesses aren't short on tools, they're short on the glue between
            them.
          </p>
          <p>
            Now I build that glue. I design and ship automation systems with n8n,
            Python, and Docker for teams in GTM, RevOps, and supply chain &
            logistics — the functions where a slow manual process directly costs
            revenue, not just time.
          </p>
        </section>

        <section class="about-section" data-reveal>
          <h2>What I do</h2>
          <p>
            I build systems, not one-off scripts. That usually means n8n handling
            orchestration and integrations, Python handling the logic that actually
            needs to compute something (scoring, optimization, allocation), and
            Docker so the whole thing runs the same on my machine, a client's VPS,
            or wherever it needs to live.
          </p>
          <p>
            Typical engagements: lead routing and follow-up automation, capacity-based
            pricing engines, ad spend allocation, route optimization, and the
            connective layer that turns five disconnected SaaS tools into one
            operating system. See <a href="/#work-heading">case studies</a> for
            specifics.
          </p>
        </section>

        <section class="about-section" data-reveal>
          <h2>Stack</h2>
          <SkillPills />
        </section>

        <section class="about-section" data-reveal>
          <h2>How I work</h2>
          <p>
            Every engagement starts as a fixed-price build, scoped on a short call —
            you know the cost before anything starts. Most clients add a monthly
            retainer afterward to keep the system maintained and growing. Full
            breakdown on the <a href="/pricing">pricing page</a>.
          </p>
        </section>

        <section class="about-section" data-reveal>
          <h2>Get in touch</h2>
          <p>
            If your team is losing time to manual GTM, RevOps, or logistics work,
            book a call and I'll scope what an automated version looks like.
          </p>
          <button
            type="button"
            class="btn btn-primary about-cta"
            data-magnetic
            data-cal-link="rajan10x/meeting-ai"
            data-cal-namespace="meeting-ai"
            data-cal-config={`{"layout":"month_view"}`}
          >
            Book a call →
          </button>
        </section>
      </main>

      <!-- Sidebar -->
      <aside class="about-sidebar" data-reveal>
        <div class="sidebar-card">
          <dl class="sidebar-list">
            <div class="sidebar-item">
              <dt class="label">Focus</dt>
              <dd>AI & Automation Consulting</dd>
            </div>
            <div class="sidebar-item">
              <dt class="label">Niches</dt>
              <dd>GTM · RevOps · Supply Chain</dd>
            </div>
            <div class="sidebar-item">
              <dt class="label">Stack</dt>
              <dd>n8n · Python · Docker</dd>
            </div>
            <div class="sidebar-item">
              <dt class="label">Location</dt>
              <dd>Nepal (remote, async)</dd>
            </div>
          </dl>

          <div class="sidebar-links">
            <button
              type="button"
              class="sidebar-link label sidebar-link--button"
              data-cal-link="rajan10x/meeting-ai"
              data-cal-namespace="meeting-ai"
              data-cal-config={`{"layout":"month_view"}`}
            >
              <img src="https://img.icons8.com/ios-filled/40/718355/calendar-2.png" alt="" width="13" height="13" class="icon" />
              Book a call
            </button>
            <a href="mailto:contact@rajanbuilds.com" class="sidebar-link label">
              <img src="https://img.icons8.com/ios-filled/40/718355/mail.png" alt="" width="13" height="13" class="icon" />
              Email
            </a>
            <a
              href="https://www.linkedin.com/in/rajan10x/"
              target="_blank"
              rel="noopener noreferrer"
              class="sidebar-link label"
            >
              <img src="https://img.icons8.com/color/48/linkedin.png" alt="" width="14" height="14" class="icon" />
              LinkedIn
            </a>
            <a
              href="https://github.com/rajanshresth"
              target="_blank"
              rel="noopener noreferrer"
              class="sidebar-link label"
            >
              <img src="https://img.icons8.com/color/48/github.png" alt="" width="14" height="14" class="icon" />
              GitHub
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Base>

<style>
  .about-layout {
    padding-bottom: 80px;
  }

  .about-header {
    padding-top: 64px;
  }

  .label {
    display: block;
    margin-bottom: 16px;
  }

  .about-title {
    font-family: var(--font-display);
    font-size: clamp(30px, 5vw, 48px);
    font-weight: 400;
    color: var(--parchment);
    line-height: 1.08;
    letter-spacing: -1px;
  }
  .about-title em {
    font-style: italic;
    color: var(--parchment-2);
  }

  /* Two-column grid */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 64px;
    align-items: start;
  }

  /* Main body */
  .about-section {
    margin-bottom: 48px;
  }
  .about-section:last-child { margin-bottom: 0; }

  .about-section h2 {
    margin-bottom: 16px;
  }

  .about-section p {
    margin-bottom: 1em;
    font-size: 14px;
  }
  .about-section p:last-of-type { margin-bottom: 0; }

  .about-cta {
    margin-top: 16px;
  }

  /* Sidebar */
  .about-sidebar {
    position: sticky;
    top: 80px;
  }

  .sidebar-card {
    background: var(--ink-2);
    border: 1px solid var(--ink-4);
    border-radius: 3px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sidebar-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .sidebar-item dt {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--parchment-4);
    margin-bottom: 3px;
    display: block;
  }

  .sidebar-item dd {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 300;
    color: var(--parchment-2);
    line-height: 1.4;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 16px;
    border-top: 1px solid var(--ink-4);
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--parchment-4);
    transition: color 150ms ease;
  }

  .sidebar-link--button {
    background: none;
    border: none;
    padding: 0;
    text-align: left;
    cursor: pointer;
  }
  .sidebar-link:hover { color: var(--copper); }

  /* Mobile */
  @media (max-width: 767px) {
    .about-layout { padding-bottom: 56px; }
    .about-header { padding-top: 44px; }
    .about-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .about-sidebar {
      position: static;
      order: -1;
    }
    .about-section { margin-bottom: 36px; }
  }
</style>
