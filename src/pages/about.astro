---
import Base from '../layouts/Base.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type':    'Person',
  name:       'Rajan Shrestha',
  url:        'https://rajanbuilds.com/about',
  jobTitle:   'AI & Automation Consultant',
  description: 'AI automation consultant building n8n, Python, and Docker systems for GTM, RevOps, and supply chain & logistics teams.',
  knowsAbout: ['n8n', 'Python', 'Docker', 'GTM Automation', 'RevOps', 'Supply Chain & Logistics'],
  address:    { '@type': 'PostalAddress', addressCountry: 'NP' },
  sameAs: [
    'https://www.linkedin.com/in/rajan10x/',
    'https://github.com/rajanshresth',
  ],
};

const techStack = ['Python', 'TypeScript', 'n8n', 'LangChain', 'AWS'];
---

<Base
  title="About — Rajan Shrestha"
  description="AI automation consultant building n8n, Python, and Docker systems for GTM, RevOps, and supply chain & logistics teams."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <div class="container about-page">
    <!-- Hero -->
    <section class="about-hero" data-reveal>
      <div class="about-hero-copy">
        <h1 class="about-title">
          I think in systems<br>
          before I think in <em>tools</em>.
        </h1>
        <p class="about-lede">
          I'm Rajan — an industrial engineer by training, now operating as an
          AI & Automation Engineer. Most businesses aren't short on tools,
          they're short on the glue between them. I build that glue.
        </p>
      </div>
      <div class="about-hero-visual">
        <img
          src="/about/hero.jpg"
          alt="A realistic technical diagram of an automation workflow showing Data Ingest, n8n Engine, and PostgreSQL database."
          width="512"
          height="512"
          class="about-hero-img"
        />
      </div>
    </section>

    <!-- Bento: Background + What I do -->
    <section class="about-bento" data-reveal-group>
      <div class="bento-card bento-background" data-spotlight>
        <h2>Background</h2>
        <div class="bento-text">
          <p>
            My background in industrial engineering deeply informs how I
            approach software and automation. It's not about writing code
            for its own sake — it's about optimizing the entire production
            line of a business.
          </p>
          <p>
            I moved into technical engineering because I kept seeing the gap
            between high-level strategic goals and the technical execution
            required to hit them efficiently.
          </p>
        </div>
      </div>

      <div class="bento-card bento-whatido" data-spotlight>
        <div>
          <h2>What I do</h2>
          <p class="bento-whatido-lede">
            I architect and deploy autonomous systems that reduce
            operational drag.
          </p>
        </div>
        <div class="bento-feature-grid">
          <div class="bento-feature">
            <img src="https://img.icons8.com/ios-filled/40/a1d1bf/hub.png" alt="" width="20" height="20" class="icon" />
            <h3 class="label">Workflow Integration</h3>
            <p>Connecting disparate platforms into singular, reliable data pipelines.</p>
          </div>
          <div class="bento-feature">
            <img src="https://img.icons8.com/ios-filled/40/a1d1bf/robot.png" alt="" width="20" height="20" class="icon" />
            <h3 class="label">AI Agents</h3>
            <p>Deploying LLMs contextually to handle reasoning tasks within fixed protocols.</p>
          </div>
          <div class="bento-feature bento-feature--wide">
            <div class="bento-feature-header">
              <span class="label bento-feature-eyebrow">Tech Stack</span>
              <div class="bento-feature-divider" aria-hidden="true"></div>
            </div>
            <div class="bento-chip-row">
              {techStack.map(tool => <span class="bento-chip">{tool}</span>)}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How I work -->
    <section class="how-i-work" data-reveal>
      <h2 class="how-i-work-heading">How I work</h2>
      <div class="how-i-work-grid">
        <div class="work-mode">
          <div class="work-mode-rail" aria-hidden="true"></div>
          <div class="work-mode-dot" aria-hidden="true"></div>
          <h3>Fixed-Price Builds</h3>
          <p>
            For defined scope and clear objectives. We map the entire system
            upfront, agree on deliverables, and I execute. No hourly
            surprises.
          </p>
          <ul class="work-mode-list" role="list">
            <li><img src="https://img.icons8.com/ios-filled/40/a1d1bf/checkmark.png" alt="" width="12" height="12" class="icon" /> Architecture design</li>
            <li><img src="https://img.icons8.com/ios-filled/40/a1d1bf/checkmark.png" alt="" width="12" height="12" class="icon" /> Implementation & testing</li>
            <li><img src="https://img.icons8.com/ios-filled/40/a1d1bf/checkmark.png" alt="" width="12" height="12" class="icon" /> Handoff documentation</li>
          </ul>
        </div>
        <div class="work-mode">
          <div class="work-mode-rail" aria-hidden="true"></div>
          <div class="work-mode-dot" aria-hidden="true"></div>
          <h3>Retainer</h3>
          <p>
            For ongoing optimization and evolving systems. Consider me your
            fractional engineering partner to continually refine the glue.
          </p>
          <ul class="work-mode-list" role="list">
            <li><img src="https://img.icons8.com/ios-filled/40/a1d1bf/checkmark.png" alt="" width="12" height="12" class="icon" /> Continuous optimization</li>
            <li><img src="https://img.icons8.com/ios-filled/40/a1d1bf/checkmark.png" alt="" width="12" height="12" class="icon" /> New integrations</li>
            <li><img src="https://img.icons8.com/ios-filled/40/a1d1bf/checkmark.png" alt="" width="12" height="12" class="icon" /> Priority support</li>
          </ul>
        </div>
      </div>
      <p class="how-i-work-footnote">
        Full breakdown on the <a href="/pricing">pricing page</a>.
      </p>
    </section>
  </div>
</Base>

<style>
  .about-page {
    padding-top: 64px;
    padding-bottom: 80px;
  }

  /* Hero */
  .about-hero {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 48px;
    align-items: center;
    margin-bottom: 96px;
  }

  .about-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    color: var(--parchment);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  .about-title em {
    font-style: normal;
    color: var(--copper);
  }

  .about-lede {
    font-size: 17px;
    max-width: 560px;
    color: var(--parchment-3);
  }

  .about-hero-visual {
    position: relative;
  }
  .about-hero-visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--copper);
    opacity: 0.1;
    filter: blur(80px);
    border-radius: 50%;
    pointer-events: none;
  }
  .about-hero-img {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 6px;
    background: var(--ink);
    border: 1px solid var(--ink-4);
  }

  /* Bento: Background + What I do */
  .about-bento {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 24px;
    margin-bottom: 96px;
  }

  .bento-card {
    background: var(--ink-2);
    border: 1px solid var(--ink-4);
    border-radius: 8px;
    padding: 32px;
  }

  .bento-card h2 {
    margin-bottom: 20px;
  }

  .bento-text {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .bento-text p {
    font-size: 14px;
  }

  .bento-whatido {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 24px;
  }

  .bento-whatido-lede {
    font-size: 16px;
    color: var(--parchment-2);
  }

  .bento-feature-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .bento-feature {
    background: var(--ink);
    border: 1px solid var(--ink-4);
    border-radius: 6px;
    padding: 16px;
  }
  .bento-feature .icon { margin-bottom: 8px; }
  .bento-feature h3 { color: var(--copper); margin-bottom: 6px; }
  .bento-feature p { font-size: 13px; }

  .bento-feature--wide {
    grid-column: span 2;
  }

  .bento-feature-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }
  .bento-feature-eyebrow { color: var(--copper); }
  .bento-feature-divider {
    height: 1px;
    background: var(--ink-4);
    flex-grow: 1;
  }

  .bento-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .bento-chip {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--parchment-2);
    background: var(--ink-2);
    border: 1px solid var(--ink-4);
    border-radius: 3px;
    padding: 5px 10px;
  }

  /* Full stack section */
  .about-section {
    margin-bottom: 96px;
  }
  .about-section h2 {
    text-align: center;
    margin-bottom: 32px;
  }

  /* How I work */
  .how-i-work-heading {
    text-align: center;
    margin-bottom: 48px;
  }

  .how-i-work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }

  .work-mode {
    position: relative;
    padding-left: 32px;
  }

  .work-mode-rail {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    border-left: 1px dashed var(--ink-4);
  }

  .work-mode-dot {
    position: absolute;
    left: -3px;
    top: 6px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--copper);
  }

  .work-mode h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    color: var(--parchment);
    margin-bottom: 12px;
  }

  .work-mode p {
    font-size: 14px;
    margin-bottom: 20px;
  }

  .work-mode-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .work-mode-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--parchment-3);
  }

  .how-i-work-footnote {
    text-align: center;
    margin-top: 40px;
    font-size: 13px;
  }
  .how-i-work-footnote a {
    color: var(--copper);
  }

  /* Mobile */
  @media (max-width: 900px) {
    .about-hero {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .about-hero-visual {
      max-width: 240px;
    }
    .about-bento {
      grid-template-columns: 1fr;
    }
    .how-i-work-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 767px) {
    .about-page { padding-top: 44px; }
    .about-hero { margin-bottom: 56px; }
    .about-bento { margin-bottom: 56px; gap: 20px; }
    .about-section { margin-bottom: 56px; }
    .bento-feature-grid { grid-template-columns: 1fr; }
    .bento-feature--wide { grid-column: span 1; }
  }
</style>
