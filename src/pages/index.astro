---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import WorkGrid from "../components/WorkGrid.astro";
import BlogPreview from "../components/BlogPreview.astro";
import SkillPills from "../components/SkillPills.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("work");
const posts = await getCollection("writing", (p) => !p.data.draft);
---

<Base
  title="Rajan — Building products that think with data"
  description="B.E. Industrial Engineering and data analyst at ING, Nepal. Using systems thinking and data analysis to build toward Product Management."
>
  <!-- Hero -->
  <Hero />

  <div class="container page-sections">
    <hr class="divider" />

    <!-- Work grid -->
    <WorkGrid projects={projects} />

    <hr class="divider section-gap" />

    <!-- Skills -->
    <section class="skills-block">
      <SkillPills />
    </section>

    <hr class="divider section-gap" />

    <!-- Blog preview -->
    <BlogPreview posts={posts} />

    <!-- Bottom spacer -->
    <div class="bottom-spacer"></div>
  </div>
</Base>

<style>
  .page-sections {
    display: flex;
    flex-direction: column;
  }

  .section-gap {
    margin-top: 5rem;
  }

  .skills-block {
    padding-block: 5rem 0;
  }

  .bottom-spacer {
    height: 3rem;
  }
</style>
