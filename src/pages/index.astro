---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import WorkList from '../components/WorkList.astro';
import BlogPreview from '../components/BlogPreview.astro';
import SkillPills from '../components/SkillPills.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const allPosts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 4);
---

<Base>
  <!-- Hero -->
  <Hero />

  <!-- Work section -->
  <section class="section container" aria-labelledby="work-heading">
    <div class="section-header">
      <h2 id="work-heading">Work</h2>
      <a href="/work/pm-roadmap-tracker" class="section-more">All projects →</a>
    </div>
    <WorkList items={allWork} />
  </section>

  <!-- Writing section -->
  <section class="section container" aria-labelledby="writing-heading">
    <div class="section-header">
      <h2 id="writing-heading">Writing</h2>
      <a href="/writing" class="section-more">All posts →</a>
    </div>
    <BlogPreview posts={allPosts} />
  </section>

  <!-- Skills section -->
  <section class="section container" aria-labelledby="skills-heading">
    <div class="section-header">
      <h2 id="skills-heading">Skills</h2>
    </div>
    <SkillPills />
  </section>
</Base>

<style>
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 28px;
    gap: 16px;
  }

  .section-more {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--copper);
    transition: opacity 150ms ease;
    flex-shrink: 0;
  }
  .section-more:hover { color: var(--copper); opacity: 0.75; }
</style>
