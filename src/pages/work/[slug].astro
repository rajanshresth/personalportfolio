---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('work');
  return items.map(item => ({
    params: { slug: item.id.replace(/\.md$/, '') },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const itemSlug  = item.id.replace(/\.md$/, '');
const siteUrl   = Astro.site ?? new URL('https://rajanbuilds.com');
const ogImage   = `/og/work/${itemSlug}.png`;
const canonical = new URL(`/work/${itemSlug}`, siteUrl).href;

const workSchema = {
  '@context':   'https://schema.org',
  '@type':      'CreativeWork',
  name:         item.data.title,
  description:  item.data.description,
  url:          canonical,
  author: {
    '@type': 'Person',
    name:    'Rajan Shrestha',
    url:     new URL('/about', siteUrl).href,
  },
  keywords: item.data.tags.join(', '),
};
---

<Base
  title={`${item.data.title} — Rajan`}
  description={item.data.description}
  image={ogImage}
  imageAlt={item.data.title}
  tags={item.data.tags}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(workSchema)} />
  <div class="container work-page">
    <!-- Breadcrumb -->
    <a href="/work" class="breadcrumb label">← Work</a>

    <!-- Header -->
    <header class="work-header">
      <div class="work-tags">
        {item.data.tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>

      <h1 class="work-title">{item.data.title}</h1>
      <p class="work-desc">{item.data.description}</p>

      {item.data.link && (
        <a
          href={item.data.link}
          target="_blank"
          rel="noopener noreferrer"
          class="work-cta label"
        >
          View project →
        </a>
      )}
    </header>

    <!-- Body -->
    <div class="prose">
      <Content />
    </div>

    <!-- Closing CTA -->
    <div class="work-end-cta" data-reveal>
      <h2>Want something like this built?</h2>
      <p>Book a 20-minute call — I'll scope it and give you an exact number.</p>
      <button
        type="button"
        class="btn btn-primary"
        data-magnetic
        data-cal-link="rajan10x/meeting-ai"
        data-cal-namespace="meeting-ai"
        data-cal-config={`{"layout":"month_view"}`}
      >
        Book a call →
      </button>
    </div>
  </div>
</Base>

<style>
  .work-page {
    padding-top: 48px;
    padding-bottom: 80px;
    max-width: 680px;
  }

  .breadcrumb {
    display: inline-block;
    margin-bottom: 40px;
    color: var(--parchment-4);
    transition: color 150ms ease;
  }
  .breadcrumb:hover { color: var(--copper); }

  .work-header {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--ink-4);
    margin-bottom: 40px;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .work-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4.5vw, 44px);
    font-weight: 700;
    color: var(--parchment);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .work-desc {
    font-size: 15px;
    max-width: 520px;
  }

  .work-cta {
    display: inline-block;
    color: var(--copper);
    margin-top: 8px;
    transition: opacity 150ms ease;
  }
  .work-cta:hover { color: var(--copper); opacity: 0.75; }

  /* Prose */
  .prose {
    color: var(--parchment-2);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.85;
  }
  .prose p { font-size: 15px; line-height: 1.85; color: var(--parchment-2); margin-bottom: 1.4em; }
  .prose h2 { font-family: var(--font-display); font-size: 24px; font-weight: 600; color: var(--parchment); margin-top: 2em; margin-bottom: 0.6em; }
  .prose h3 { font-family: var(--font-body); font-size: 16px; font-weight: 500; color: var(--parchment-2); margin-top: 1.6em; margin-bottom: 0.4em; }
  .prose ul { list-style: disc; padding-left: 1.5em; margin-bottom: 1.4em; }
  .prose ol { list-style: decimal; padding-left: 1.5em; margin-bottom: 1.4em; }
  .prose li { margin-bottom: 0.4em; }
  .prose code:not(pre code) { font-family: var(--font-mono); font-size: 12px; background: var(--ink-3); color: var(--parchment-2); padding: 2px 6px; border-radius: 2px; }
  .prose pre { font-family: var(--font-mono); font-size: 12px; background: var(--ink-2); border: 1px solid var(--ink-4); border-radius: 4px; padding: 1rem 1.25rem; overflow-x: auto; margin-bottom: 1.4em; }
  .prose pre code { background: none; padding: 0; color: var(--parchment-2); }
  .prose a { color: var(--copper); }

  /* Closing CTA */
  .work-end-cta {
    margin-top: 56px;
    padding-top: 40px;
    border-top: 1px solid var(--ink-4);
    text-align: center;
  }
  .work-end-cta h2 { margin-bottom: 8px; }
  .work-end-cta p { margin-bottom: 20px; }

  @media (max-width: 600px) {
    .work-end-cta { margin-top: 40px; padding-top: 32px; }
  }
</style>
