---
import Base from '../../layouts/Base.astro';
import BlogSearch from '../../components/BlogSearch.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<Base
  title="Writing — Rajan"
  description="Essays on product thinking, industrial systems, and transitioning from engineering to PM."
>
  <div class="container">
    <section class="writing-header section">
      <span class="label">Writing</span>
      <h1 class="writing-title">
        Thinking out loud
      </h1>
      <p class="writing-desc">
        Essays on product thinking, industrial systems, and the process of going from engineering to PM.
      </p>
    </section>

    <section class="section" aria-label="Posts">
      <BlogSearch posts={posts} postsPerPage={6} />
    </section>
  </div>
</Base>

<style>
  .writing-header {
    padding-top: 64px;
  }

  .label {
    display: block;
    margin-bottom: 16px;
  }

  .writing-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 400;
    color: var(--parchment);
    line-height: 1.1;
    letter-spacing: -0.8px;
    margin-bottom: 16px;
  }

  .writing-desc {
    max-width: 480px;
    font-size: 14px;
  }
</style>
